---
// Count-up is driven by the existing IntersectionObserver in BaseLayout.astro
// via the `data-countup` attribute (parses $-prefix, digits, suffix).
const stats = [
  {
    label: "First-Year Growth",
    sub: "Avg. booking lift across clients",
    display: "63%+",
    iconPath:
      "M3 17l6-6 4 4 8-8 M14 7l7 0 0 7",
  },
  {
    label: "Campaigns Managed",
    sub: "Shipped, measured, refined",
    display: "2,000+",
    iconPath: "M20 6L9 17l-5-5",
  },
  {
    label: "Ad Spend Managed",
    sub: "Monthly, across paid channels",
    display: "$100K+",
    iconPath: "M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",
  },
  {
    label: "Practices Growing",
    sub: "Across 14 states",
    display: "41",
    iconPath: "M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z M12 10 m-3 0 a3 3 0 1 0 6 0 a3 3 0 1 0 -6 0",
  },
];
---

<section class="stats">
  <div class="stats__inner">
    <h2 class="stats__head">Trusted by Small Businesses</h2>
    <div class="stats__grid">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={s.iconPath} />
            </svg>
          </div>
          <div class="stat__num" data-countup={s.display}>{s.display}</div>
          <div class="stat__label">{s.label}</div>
          <div class="stat__sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: #fff;
    color: var(--ink-900);
    padding: 56px var(--pad);
    position: relative;
    border-top: 1px solid var(--ink-100);
    border-bottom: 1px solid var(--ink-100);
  }
  .stats__inner {
    position: relative;
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .stats__head {
    text-align: center;
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 700;
    margin: 0 0 32px;
    letter-spacing: -0.01em;
    color: var(--ink-900);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .stat {
    background: var(--paper);
    border: 1px solid var(--ink-100);
    border-radius: var(--radius);
    padding: 22px 20px 20px;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }
  .stat:hover {
    background: #fff;
    border-color: var(--teal-200);
    transform: translateY(-2px);
  }
  .stat__icon {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: var(--teal-50);
    color: var(--teal);
    display: grid;
    place-items: center;
    margin-bottom: 14px;
  }
  .stat__num {
    font-size: clamp(32px, 3.2vw, 44px);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 6px;
    color: var(--teal);
    font-variant-numeric: tabular-nums;
  }
  .stat__label {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink-900);
  }
  .stat__sub {
    font-size: 13px;
    color: var(--ink-500);
    margin-top: 3px;
  }

  @media (max-width: 820px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
