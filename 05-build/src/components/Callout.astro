---
interface Props {
  type?: "info" | "warning" | "success" | "tip";
  title?: string;
}
const { type = "info", title } = Astro.props;

const icons: Record<string, string> = {
  info: "M12 16v-4M12 8h.01M22 12a10 10 0 1 1-20 0 10 10 0 0 1 20 0Z",
  warning:
    "M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0ZM12 9v4M12 17h.01",
  success: "M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4 12 14.01l-3-3",
  tip: "M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.74V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.26A7 7 0 0 0 12 2Z",
};
---

<aside class:list={["callout", `callout--${type}`]} role="note">
  <div class="callout-icon" aria-hidden="true">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d={icons[type]} />
    </svg>
  </div>
  <div class="callout-body">
    {title && <p class="callout-title">{title}</p>}
    <div class="callout-content">
      <slot />
    </div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    border-radius: 0.625rem;
    border: 1px solid var(--callout-border, #e5e7eb);
    background: var(--callout-bg, #f9fafb);
    color: var(--callout-text, var(--color-ink));
    margin: 1.5rem 0;
    line-height: 1.6;
  }

  .callout-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    color: var(--callout-icon-color, var(--color-brand-dark));
    background: var(--callout-icon-bg, rgba(255, 255, 255, 0.8));
  }

  .callout-body {
    flex: 1;
    min-width: 0;
  }

  .callout-title {
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0 0 0.25rem;
    color: var(--callout-title-color, var(--color-ink));
    line-height: 1.35;
  }

  .callout-content > :first-child { margin-top: 0; }
  .callout-content > :last-child { margin-bottom: 0; }
  .callout-content :global(p) { margin: 0.4rem 0; }
  .callout-content :global(p:first-child) { margin-top: 0; }
  .callout-content :global(p:last-child) { margin-bottom: 0; }

  /* Info — brand cyan */
  .callout--info {
    --callout-bg: #ecfeff;
    --callout-border: rgba(6, 182, 212, 0.3);
    --callout-text: #155e75;
    --callout-title-color: #155e75;
    --callout-icon-bg: rgba(6, 182, 212, 0.18);
    --callout-icon-color: var(--color-brand-darker);
  }

  /* Tip — softer green */
  .callout--tip {
    --callout-bg: #f0fdf4;
    --callout-border: rgba(74, 222, 128, 0.4);
    --callout-text: #14532d;
    --callout-title-color: #14532d;
    --callout-icon-bg: rgba(74, 222, 128, 0.2);
    --callout-icon-color: #15803d;
  }

  /* Success — green check */
  .callout--success {
    --callout-bg: #f0fdf4;
    --callout-border: rgba(34, 197, 94, 0.45);
    --callout-text: #14532d;
    --callout-title-color: #14532d;
    --callout-icon-bg: rgba(34, 197, 94, 0.2);
    --callout-icon-color: #15803d;
  }

  /* Warning — amber */
  .callout--warning {
    --callout-bg: #fffbeb;
    --callout-border: rgba(245, 158, 11, 0.4);
    --callout-text: #78350f;
    --callout-title-color: #78350f;
    --callout-icon-bg: rgba(245, 158, 11, 0.2);
    --callout-icon-color: #b45309;
  }
</style>
