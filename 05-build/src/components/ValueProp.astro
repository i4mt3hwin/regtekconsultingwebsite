---
const cards = [
  {
    num: "01",
    title: "Operations Experience",
    body:
      "Our founders ran operations for a healthcare clinic that scaled to 5 offices and earned Inc. 5000 recognition. We understand the full picture — not just clicks and impressions, but revenue, capacity, and patient lifetime value.",
    href: "/about",
    feature: false,
  },
  {
    num: "02",
    title: "True Partnership",
    body:
      "You work directly with the founder. No account managers, no middle tier. We become an extension of your team, offering strategic guidance that goes beyond marketing to help your entire business thrive.",
    href: "/about",
    feature: true,
  },
  {
    num: "03",
    title: "Data-Driven Decisions",
    body:
      "We focus on what matters: ROI, new patients, and actual revenue generated. No vanity metrics like “impressions” or “engagement.” Every dollar you invest should drive measurable business results — and we show you exactly how.",
    href: "/services",
    feature: false,
  },
];
---

<section class="vprop" id="why-regtek">
  <div class="vprop__inner">
    <div class="vprop__header">
      <div class="eyebrow eyebrow--center">Why Regtek</div>
      <h2 class="rk-h2">
        You've built something great through word-of-mouth.<br />
        <span class="rk-accent rk-accent--underline">Now it's time to scale.</span>
      </h2>
      <p class="rk-lede">
        You've done the hard part — building a business that delivers real value. But you've hit a ceiling: your network can only refer so many people, and relying on word-of-mouth creates that feast-or-famine cycle you're tired of.
        <b>That's exactly where we come in.</b>
      </p>
    </div>

    <div class="vprop__grid">
      {cards.map((c) => (
        <article class:list={["vcard", { "vcard--feature": c.feature }]}>
          {c.feature && <div class="vcard__badge">Most requested</div>}
          <div class="vcard__num">{c.num}</div>
          <h3 class="vcard__title">{c.title}</h3>
          <p class="vcard__body">{c.body}</p>
          <a class="vcard__link" href={c.href}>Read more <span>&rarr;</span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .vprop {
    padding: 72px var(--pad);
    background: #fff;
  }
  .vprop__inner {
    max-width: var(--maxw);
    margin: 0 auto;
  }
  .vprop__header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 60px;
  }
  .vprop__header :global(.rk-h2) { text-align: center; }
  .vprop__header :global(.rk-lede b) { color: var(--ink-900); }

  .vprop__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .vcard {
    position: relative;
    background: #fff;
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-lg);
    padding: 32px 28px 28px;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .vcard:hover {
    border-color: var(--teal-200);
    box-shadow: var(--shadow);
    transform: translateY(-3px);
  }
  .vcard--feature {
    background: var(--ink-900);
    color: var(--ink-100);
    border-color: var(--ink-900);
  }
  .vcard--feature:hover {
    border-color: var(--teal);
    box-shadow: 0 20px 40px -20px color-mix(in oklab, var(--teal) 60%, transparent);
  }

  .vcard__badge {
    position: absolute;
    top: -11px;
    left: 28px;
    background: var(--lime);
    color: var(--ink-900);
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 999px;
    letter-spacing: 0.03em;
  }
  .vcard__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--teal-50);
    color: var(--teal);
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
  }
  .vcard--feature .vcard__num {
    background: rgba(255, 255, 255, 0.1);
    color: var(--lime);
  }
  .vcard__title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink-900);
    margin: 0 0 10px;
  }
  .vcard--feature .vcard__title { color: #fff; }
  .vcard__body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-600);
    margin: 0 0 20px;
  }
  .vcard--feature .vcard__body { color: var(--ink-200); }
  .vcard__link {
    font-size: 14px;
    font-weight: 600;
    color: var(--teal);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .vcard__link span { transition: transform 0.2s ease; }
  .vcard__link:hover span { transform: translateX(3px); }
  .vcard--feature .vcard__link { color: var(--lime); }

  @media (max-width: 900px) {
    .vprop__grid { grid-template-columns: 1fr; }
  }
</style>
