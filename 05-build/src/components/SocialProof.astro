---
// 3-avatar social proof block: testimonial faces + gold stars + "5 Star Client Reviews".
// Reused on homepage, services hub, and each service detail page.
---

<div class="flex -space-x-2.5 md:-space-x-3">
  <img
    src="/images/testimonials/Elise-Basinger.webp"
    alt="Elise Basinger, Owner of Menon Regenerative Institute"
    width="64"
    height="64"
    class="w-11 h-11 md:w-14 md:h-14 rounded-full border-2 md:border-3 border-white object-cover shadow-sm"
  />
  <img
    src="/images/testimonials/unnamed-48.webp"
    alt="Regtek client"
    width="64"
    height="64"
    class="w-11 h-11 md:w-14 md:h-14 rounded-full border-2 md:border-3 border-white object-cover shadow-sm"
  />
  <img
    src="/images/testimonials/unnamed-47.webp"
    alt="Regtek client"
    width="64"
    height="64"
    class="w-11 h-11 md:w-14 md:h-14 rounded-full border-2 md:border-3 border-white object-cover shadow-sm"
  />
</div>
<div class="flex flex-col">
  <span class="text-yellow-400 text-2xl md:text-3xl leading-none">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
  <span class="text-sm md:text-base text-[color:var(--color-brand)] font-semibold mt-0.5 md:mt-1">5 Star Client Reviews</span>
</div>
