    src="/images/testimonials/Elise-Basinger.webp"
    alt="Elise Basinger, Owner of Menon Regenerative Institute"
    width="56"
    height="56"
    class="w-14 h-14 rounded-full border-3 border-white object-cover shadow-sm"
  />
  <img
    src="/images/testimonials/unnamed-48.webp"
    alt="Regtek client"
    width="56"
    height="56"
    class="w-14 h-14 rounded-full border-3 border-white object-cover shadow-sm"
  />
  <img
    src="/images/testimonials/unnamed-47.webp"
    alt="Regtek client"
    width="56"
    height="56"
    class="w-14 h-14 rounded-full border-3 border-white object-cover shadow-sm"
  />
</div>
<div class="flex flex-col">
  <span class="text-yellow-400 text-3xl leading-none">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
  <span class="text-base text-[color:var(--color-brand)] font-semibold mt-1">5 Star Client Reviews</span>
