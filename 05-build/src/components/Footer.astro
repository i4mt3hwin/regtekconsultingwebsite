---
import { SERVICES, SITE } from "../lib/site";

const year = new Date().getFullYear();
---

<footer class="bg-gray-800 text-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <h3 class="text-3xl font-bold">
          <span class="text-white">Reg</span><span class="text-[color:var(--color-brand)]">tek</span>
        </h3>
        <p class="mt-4 text-sm text-gray-300 leading-relaxed">
          {SITE.tagline}
        </p>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          Named after our founder's best friend 🐕
        </p>
      </div>

      <div>
        <h3 class="text-lg font-bold text-white mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-300 hover:text-[color:var(--color-brand)]">About us</a></li>
          <li><a href="/services" class="text-sm text-gray-300 hover:text-[color:var(--color-brand)]">Services</a></li>
          <li><a href="/contact" class="text-sm text-gray-300 hover:text-[color:var(--color-brand)]">Contact</a></li>
          <li><a href="/blog" class="text-sm text-gray-300 hover:text-[color:var(--color-brand)]">Tips & Tricks</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-white mb-4">Services</h3>
        <ul class="space-y-2">
          {SERVICES.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-gray-300 hover:text-[color:var(--color-brand)]">
                {s.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-white mb-4">Contact Us</h3>
        <ul class="space-y-2">
          <li>
            <a href={`tel:${SITE.phone.replace(/[^0-9+]/g, "")}`} class="text-sm text-[color:var(--color-brand)] hover:underline">
              Phone: {SITE.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="text-sm text-[color:var(--color-brand)] hover:underline">
              Email: {SITE.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-700 text-xs text-gray-400">
      <p>&copy;{year} {SITE.name} - All rights reserved</p>
    </div>
  </div>
</footer>
