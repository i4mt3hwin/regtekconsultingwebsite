---
import { SERVICES } from "../lib/site";
import { getSiteSettings } from "../lib/content";

const site = getSiteSettings();
const year = new Date().getFullYear();
---

<footer class="bg-gray-800 text-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <div class="text-2xl font-bold">
          <span class="text-[color:var(--color-brand)]">Reg</span>tek
        </div>
        <p class="mt-3 text-sm text-gray-300 leading-relaxed">
          {site.tagline}
        </p>
        <p class="mt-3 text-xs text-gray-400 leading-relaxed">
          {site.footerStory}
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-4">Services</h3>
        <ul class="space-y-2">
          {SERVICES.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-gray-200 hover:text-[color:var(--color-brand)]">
                {s.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-4">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-200 hover:text-[color:var(--color-brand)]">About</a></li>
          <li><a href="/blog" class="text-sm text-gray-200 hover:text-[color:var(--color-brand)]">Blog</a></li>
          <li><a href="/contact" class="text-sm text-gray-200 hover:text-[color:var(--color-brand)]">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-4">Get Started</h3>
        <a
          href="/contact"
          class="inline-flex items-center px-5 py-2.5 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors shadow-sm"
        >
          Book a Free Call
        </a>
        <p class="mt-4 text-xs text-gray-400">
          <a href={`mailto:${site.contactEmail}`} class="hover:text-[color:var(--color-brand)]">
            {site.contactEmail}
          </a>
        </p>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-700 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-gray-400">
      <p>&copy; {year} {site.siteName}. All rights reserved.</p>
      <p>Founder-led marketing for healthcare practices.</p>
    </div>
  </div>
</footer>
