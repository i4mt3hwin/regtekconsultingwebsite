---
interface Props {
  attribution?: string;
}
const { attribution } = Astro.props;
---

<figure class="pull-quote">
  <blockquote class="pull-quote-text">
    <slot />
  </blockquote>
  {attribution && (
    <figcaption class="pull-quote-attribution">— {attribution}</figcaption>
  )}
</figure>

<style>
  .pull-quote {
    position: relative;
    margin: 2.25rem 0;
    padding: 1.5rem 1.5rem 1.5rem 3.5rem;
    border-left: 4px solid var(--color-brand);
    background: linear-gradient(
      135deg,
      rgba(6, 182, 212, 0.06),
      rgba(74, 222, 128, 0.04)
    );
    border-radius: 0 0.875rem 0.875rem 0;
    isolation: isolate;
  }

  .pull-quote::before {
    content: "“";
    position: absolute;
    top: 0.25rem;
    left: 1rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 4.5rem;
    line-height: 1;
    color: var(--color-brand);
    opacity: 0.55;
    font-weight: 700;
    pointer-events: none;
    z-index: -1;
  }

  .pull-quote-text {
    margin: 0;
    padding: 0;
    border: 0;
    font-size: 1.25rem;
    line-height: 1.5;
    font-weight: 600;
    color: var(--color-ink);
    font-style: normal;
    background: none;
  }
  @media (min-width: 768px) {
    .pull-quote-text {
      font-size: 1.5rem;
      line-height: 1.45;
    }
  }

  .pull-quote-text :global(p) {
    margin: 0;
    color: inherit;
    font-size: inherit;
    font-weight: inherit;
  }
  .pull-quote-text :global(p + p) {
    margin-top: 0.75rem;
  }

  .pull-quote-attribution {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-brand-darker);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }
</style>
