---
import { NAV, SITE } from "../lib/site";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header id="site-header" class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-100 transition-transform duration-300 will-change-transform">
  <div class="max-w-6xl mx-auto pl-6 pr-4 md:px-6 py-2 md:py-4 flex items-center justify-between">
    <a href="/" class="flex items-center group" aria-label={SITE.name}>
      <img
        src="/images/brand/regtek-logo.png"
        alt="Regtek Consulting"
        width="326"
        height="326"
        class="h-11 md:h-[129px] w-auto"
      />
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Main navigation">
      {NAV.map((item) => (
        <div class="relative group">
          <a
            href={item.href}
            class:list={[
              "font-medium text-lg transition-colors",
              isActive(item.href)
                ? "text-[color:var(--color-brand)]"
                : "text-[color:var(--color-ink)] hover:text-[color:var(--color-brand)]",
            ]}
          >
            {item.label}
            {item.children && <span class="ml-1 text-xs">&#9662;</span>}
          </a>
          {item.children && (
            <div class="absolute top-full left-0 pt-3 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-opacity">
              <div class="bg-white shadow-lg rounded-lg border border-gray-100 py-2 min-w-56">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-[color:var(--color-brand)]"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <a
      href="/contact"
      class="hidden md:inline-flex items-center px-7 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold text-base rounded-md hover:bg-[color:var(--color-brand-darker)] transition-shadow shadow-xl hover:shadow-2xl"
    >
      Book Free Consultation
    </a>

    <button
      type="button"
      id="mobile-menu-toggle"
      class="md:hidden p-2 mr-1 rounded-md text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)] transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="2.25" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-gray-100 bg-white">
    <nav class="px-6 py-4 flex flex-col gap-1" aria-label="Mobile navigation">
      {NAV.map((item) => (
        <>
          <a
            href={item.href}
            class="py-2 font-medium text-[color:var(--color-ink)] hover:text-[color:var(--color-brand)]"
          >
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4 flex flex-col gap-1 pb-2">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="py-1.5 text-sm text-gray-800 hover:text-[color:var(--color-brand)]"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </>
      ))}
      <a
        href="/contact"
        class="mt-3 inline-flex justify-center px-5 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md shadow-lg hover:shadow-xl transition-shadow"
      >
        Book Free Consultation
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const header = document.getElementById("site-header");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", (!expanded).toString());
    menu?.classList.toggle("hidden");
    // Always show the header when the menu opens
    header?.classList.remove("header-hidden");
  });

  // Auto-hide header on mobile when scrolling down, show on scroll up
  if (header) {
    const mobileMQ = window.matchMedia("(max-width: 767px)");
    const SHOW_AT = 80; // px from top — always show header above this
    const DELTA = 6;    // ignore tiny scroll jitter
    let lastY = window.scrollY;
    let ticking = false;

    const updateHeader = () => {
      const y = window.scrollY;
      const isMobile = mobileMQ.matches;
      const menuOpen = toggle?.getAttribute("aria-expanded") === "true";

      if (!isMobile || menuOpen || y < SHOW_AT) {
        header.classList.remove("header-hidden");
      } else if (y > lastY + DELTA) {
        header.classList.add("header-hidden");
      } else if (y < lastY - DELTA) {
        header.classList.remove("header-hidden");
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(updateHeader);
          ticking = true;
        }
      },
      { passive: true },
    );

    // Reset to visible when crossing the breakpoint
    mobileMQ.addEventListener("change", () => {
      header.classList.remove("header-hidden");
    });
  }
</script>

<style>
  #site-header.header-hidden {
    transform: translateY(-100%);
  }
</style>
