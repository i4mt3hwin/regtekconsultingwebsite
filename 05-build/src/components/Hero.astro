---
// Right-side visual: "photo" frame + floating schedule + growth-chart cards.
// Copy and structure match design-reference/Regtek.html.
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__copy">
      <div class="eyebrow">Small Business Digital Marketing</div>
      <h1 class="hero__title">
        Turn Your Marketing Into<br />
        <span class="rk-accent">Predictable Revenue</span>
      </h1>
      <p class="hero__sub">
        Work directly with a founder who ran operations at a healthcare company that scaled to <b>5 offices and Inc. 5000 recognition</b>. Strategic guidance that goes beyond marketing — backed by operator experience, not just agency playbooks.
      </p>

      <div class="hero__cta-row">
        <a class="rk-btn rk-btn--teal rk-btn--lg" href="/contact">
          Book Your Free Consultation Today
          <span class="rk-btn__arrow">&rarr;</span>
        </a>
      </div>

      <div class="hero__trust">
        <div class="stars" aria-label="5 star rating">
          <svg viewBox="0 0 100 20" width="110" height="22" aria-hidden="true"><g fill="#F5B400">
            <polygon points="10,0 13,7 20,7 14,12 16,19 10,15 4,19 6,12 0,7 7,7" />
            <polygon points="30,0 33,7 40,7 34,12 36,19 30,15 24,19 26,12 20,7 27,7" />
            <polygon points="50,0 53,7 60,7 54,12 56,19 50,15 44,19 46,12 40,7 47,7" />
            <polygon points="70,0 73,7 80,7 74,12 76,19 70,15 64,19 66,12 60,7 67,7" />
            <polygon points="90,0 93,7 100,7 94,12 96,19 90,15 84,19 86,12 80,7 87,7" />
          </g></svg>
        </div>
        <div class="hero__trust-text">
          <b>5-Star Rated</b> · Small business marketing that actually books patients
        </div>
      </div>

      <div class="hero__badge">
        <div class="badge-op" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7 9 18l-5-5" /></svg>
        </div>
        <div class="badge-text">
          <b>Operator, not an agency rep</b><br />
          <span>Former Ops Manager at a 5-office, Inc. 5000 healthcare company</span>
        </div>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hv__photo">
        <div class="hv__ph-bg" aria-hidden="true"></div>
        <div class="hv__ph-label">
          <span class="ph-tag">PHOTO</span>
          <span class="ph-sub">Kevin &amp; Reggie</span>
        </div>
        <svg class="hv__reggie" viewBox="0 0 80 80" aria-hidden="true">
          <path
            d="M20 70 Q20 50 28 42 Q24 38 26 30 Q30 32 32 36 Q42 30 52 38 Q58 34 62 36 Q60 42 56 44 Q62 50 62 60 L62 70 Z"
            fill="#0E7C86"
            opacity="0.15"
          />
        </svg>
      </div>

      <div class="hv__card hv__card--schedule" aria-hidden="true">
        <div class="mini-cal">
          <div class="mini-cal__head">
            <span class="mini-cal__t">Bright Smile Dental</span>
            <span class="mini-cal__live"><i></i>Live</span>
          </div>
          <div class="mini-cal__row"><span class="time">9:00</span><span class="slot booked">Consult — J. Park</span></div>
          <div class="mini-cal__row"><span class="time">9:45</span><span class="slot booked">Cleaning — M. Liu</span></div>
          <div class="mini-cal__row"><span class="time">10:30</span><span class="slot booked">New Patient</span></div>
          <div class="mini-cal__row"><span class="time">11:15</span><span class="slot booked">Whitening</span></div>
          <div class="mini-cal__row"><span class="time">12:00</span><span class="slot booked">Consult</span></div>
          <div class="mini-cal__row new"><span class="time">12:45</span><span class="slot booked anim">New booking · just now</span></div>
        </div>
      </div>

      <div class="hv__card hv__card--growth" aria-hidden="true">
        <div class="growth__top">
          <span class="growth__label">Monthly Bookings</span>
          <span class="growth__delta">+63%</span>
        </div>
        <svg class="growth__chart" viewBox="0 0 160 48" preserveAspectRatio="none">
          <defs>
            <linearGradient id="hero-growth-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#0E7C86" stop-opacity="0.35" />
              <stop offset="100%" stop-color="#0E7C86" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path d="M0,38 L20,36 L40,32 L60,30 L80,24 L100,20 L120,14 L140,10 L160,6 L160,48 L0,48 Z" fill="url(#hero-growth-grad)" />
          <path d="M0,38 L20,36 L40,32 L60,30 L80,24 L100,20 L120,14 L140,10 L160,6" fill="none" stroke="#0E7C86" stroke-width="2" />
          <circle cx="160" cy="6" r="3.5" fill="#0E7C86" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse 60% 70% at 90% 0%, var(--teal-50) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 0% 100%, var(--teal-50) 0%, transparent 55%),
      linear-gradient(180deg, #fff 0%, var(--paper) 100%);
    padding: 56px var(--pad) 72px;
  }

  .hero__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .hero__title {
    font-size: clamp(40px, 5.2vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.028em;
    font-weight: 800;
    color: var(--ink-900);
    margin: 0 0 22px;
    text-wrap: balance;
  }
  .hero__title :global(.rk-accent) {
    background: linear-gradient(90deg, var(--teal) 0%, #14a0ad 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero__sub {
    font-size: clamp(16px, 1.2vw, 19px);
    line-height: 1.65;
    color: var(--ink-600);
    max-width: 56ch;
    margin: 0 0 32px;
  }
  .hero__sub b { color: var(--ink-900); }

  .hero__cta-row { margin-bottom: 28px; }

  .hero__trust {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
  }
  .hero__trust-text { font-size: 14px; color: var(--ink-600); }
  .hero__trust-text b { color: var(--ink-900); }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 12px 18px 12px 12px;
    background: linear-gradient(135deg, var(--teal) 0%,
      color-mix(in oklab, var(--teal) 70%, #14a0ad) 100%);
    color: #fff;
    border: 1px solid color-mix(in oklab, var(--teal) 60%, #000);
    border-radius: var(--radius);
    box-shadow:
      0 10px 24px -10px color-mix(in oklab, var(--teal) 60%, transparent),
      var(--shadow-sm);
    position: relative;
  }
  .hero__badge::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.18) 0%, transparent 45%);
    pointer-events: none;
  }
  .badge-op {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: var(--lime);
    color: var(--ink-900);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2);
  }
  .badge-text {
    font-size: 13px;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.9);
    position: relative;
  }
  .badge-text b { color: #fff; font-size: 14px; }
  .badge-text span { color: rgba(255, 255, 255, 0.75); }

  .hero__visual {
    position: relative;
    min-height: 520px;
  }
  .hv__photo {
    position: relative;
    aspect-ratio: 4/5;
    max-width: 420px;
    margin-left: auto;
    border-radius: 24px;
    overflow: hidden;
    background:
      radial-gradient(ellipse 100% 80% at 50% 100%, var(--teal-100) 0%, transparent 70%),
      linear-gradient(165deg, var(--teal-50) 0%, #fff 100%);
    border: 1px solid var(--ink-100);
    box-shadow: var(--shadow-lg);
  }
  .hv__ph-bg {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      45deg,
      transparent 0 14px,
      color-mix(in oklab, var(--teal) 6%, transparent) 14px 28px
    );
  }
  .hv__ph-label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: var(--teal);
  }
  .ph-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    padding: 4px 10px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--teal-200);
  }
  .ph-sub {
    font-size: 22px;
    font-weight: 700;
    color: var(--ink-900);
    letter-spacing: -0.01em;
  }
  .hv__reggie {
    position: absolute;
    right: 6%;
    bottom: 0;
    width: 36%;
    height: auto;
  }

  .hv__card {
    position: absolute;
    background: #fff;
    border: 1px solid var(--ink-100);
    border-radius: 14px;
    box-shadow: var(--shadow-lg);
    padding: 14px;
  }
  .hv__card--schedule {
    left: -8px;
    top: 28px;
    width: 260px;
    padding: 12px 14px 8px;
    animation: rk-floatA 6s ease-in-out infinite;
  }
  .hv__card--growth {
    right: -14px;
    bottom: 12px;
    width: 230px;
    padding: 14px 16px 12px;
    animation: rk-floatB 7s ease-in-out infinite;
  }
  @keyframes rk-floatA {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  @keyframes rk-floatB {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .mini-cal__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 8px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--ink-100);
  }
  .mini-cal__t {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--ink-900);
  }
  .mini-cal__live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1f9e63;
  }
  .mini-cal__live i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.2);
    animation: rk-pulse 1.6s ease-in-out infinite;
  }
  @keyframes rk-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .mini-cal__row {
    display: grid;
    grid-template-columns: 42px 1fr;
    align-items: center;
    gap: 10px;
    padding: 4px 0;
    font-size: 12px;
  }
  .mini-cal__row .time {
    color: var(--ink-500);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .mini-cal__row .slot {
    background: var(--teal-50);
    color: var(--teal-700);
    padding: 5px 8px;
    border-radius: 6px;
    font-weight: 600;
    border-left: 2px solid var(--teal);
  }
  .mini-cal__row.new .slot.anim {
    background: color-mix(in oklab, var(--lime) 30%, white);
    color: var(--ink-900);
    border-left-color: var(--ink-900);
    animation: rk-newrow 2s ease-out;
  }
  @keyframes rk-newrow {
    0% { transform: translateX(10px); opacity: 0; }
    100% { transform: translateX(0); opacity: 1; }
  }

  .growth__top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 4px;
  }
  .growth__label {
    font-size: 11px;
    font-weight: 600;
    color: var(--ink-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .growth__delta {
    font-size: 22px;
    font-weight: 800;
    color: var(--teal);
    letter-spacing: -0.02em;
  }
  .growth__chart {
    width: 100%;
    height: 48px;
    display: block;
  }

  @media (max-width: 980px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero__visual { min-height: 460px; }
    .hv__photo { max-width: 340px; margin: 0 auto; }
    .hv__card--schedule { left: 0; }
    .hv__card--growth { right: 0; }
  }
  @media (max-width: 640px) {
    .hero__badge { gap: 10px; padding: 10px 14px 10px 10px; }
    .hv__card--schedule { width: 230px; }
    .hv__card--growth { width: 200px; }
  }
</style>
