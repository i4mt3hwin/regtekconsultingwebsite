---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";
import SchemaOrg from "../components/SchemaOrg.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, ogImage, noindex, extraSchema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <SEO {title} {description} {canonical} {ogImage} {noindex} />
    <SchemaOrg {extraSchema} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const els = document.querySelectorAll("[data-countup]");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const raw = el.dataset.countup || "";
              observer.unobserve(el);

              // Parse: extract numeric part, prefix ($), suffix (+, %, K+)
              const match = raw.match(/^(\$?)([0-9,]+)(.*)/);
              if (!match) return;
              const prefix = match[1];
              const targetNum = parseInt(match[2].replace(/,/g, ""), 10);
              const suffix = match[3];

              let current = 0;
              const duration = 1500;
              const steps = 40;
              const increment = targetNum / steps;
              const stepTime = duration / steps;

              el.textContent = prefix + "0" + suffix;

              const timer = setInterval(() => {
                current += increment;
                if (current >= targetNum) {
                  current = targetNum;
                  clearInterval(timer);
                }
                const formatted = Math.round(current).toLocaleString("en-US");
                el.textContent = prefix + formatted + suffix;
              }, stepTime);
            });
          },
          { threshold: 0.5 }
        );

        els.forEach((el) => observer.observe(el));

        // Case-study reveal: add .in-view once container is 20% visible
        const csContainers = document.querySelectorAll("[data-cs-scroll]");
        if (csContainers.length) {
          const csObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  csObserver.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.2 }
          );
          csContainers.forEach((el) => csObserver.observe(el));
        }

        // Scroll-linked reveal — adds/removes .revealed based on visibility
        const revealEls = document.querySelectorAll("[data-reveal]");
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
              } else {
                entry.target.classList.remove("revealed");
              }
            });
          },
          { threshold: 0.15 }
        );
        revealEls.forEach((el) => revealObserver.observe(el));

        // Animated underline — play once, stay drawn
        const underlineEls = document.querySelectorAll(".cs-underline-animate");
        const underlineObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
                underlineObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 }
        );
        underlineEls.forEach((el) => underlineObserver.observe(el));

        // Parallax background images
        const parallaxSections = document.querySelectorAll("[data-parallax-bg]");
        if (parallaxSections.length) {
          function updateParallax() {
            parallaxSections.forEach((section) => {
              const rect = section.getBoundingClientRect();
              const img = section.querySelector(".parallax-bg-img") as HTMLElement;
              if (!img) return;
              const speed = 0.3;
              const offset = rect.top * speed;
              img.style.transform = `translateY(${offset}px) scale(1.2)`;
            });
            requestAnimationFrame(updateParallax);
          }
          requestAnimationFrame(updateParallax);
        }

        // Multi-strip horizontal parallax (each strip moves at its own speed/direction)
        const stripSections = document.querySelectorAll("[data-parallax-strips]");
        if (stripSections.length) {
          const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          function updateStrips() {
            stripSections.forEach((section) => {
              const rect = section.getBoundingClientRect();
              const vh = window.innerHeight;
              const progress = (rect.top + rect.height / 2 - vh / 2) / vh;
              const strips = section.querySelectorAll<HTMLElement>(".parallax-strip");
              strips.forEach((strip) => {
                const speed = parseFloat(strip.dataset.stripSpeed || "0.5");
                const direction = parseFloat(strip.dataset.stripDirection || "1");
                const range = parseFloat(strip.dataset.stripRange || "240");
                const offset = reducedMotion ? 0 : direction * speed * progress * range;
                strip.style.transform = `translate3d(${offset.toFixed(1)}px, 0, 0)`;
              });
            });
            requestAnimationFrame(updateStrips);
          }
          requestAnimationFrame(updateStrips);
        }
      });
    </script>
  </body>
</html>
