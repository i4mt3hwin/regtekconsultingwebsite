---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";
import SchemaOrg from "../components/SchemaOrg.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonical, ogImage, noindex, extraSchema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO {title} {description} {canonical} {ogImage} {noindex} />
    <SchemaOrg {extraSchema} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const els = document.querySelectorAll("[data-countup]");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const el = entry.target as HTMLElement;
              const raw = el.dataset.countup || "";
              observer.unobserve(el);

              // Parse: extract numeric part, prefix ($), suffix (+, %, K+)
              const match = raw.match(/^(\$?)([0-9,]+)(.*)/);
              if (!match) return;
              const prefix = match[1];
              const targetNum = parseInt(match[2].replace(/,/g, ""), 10);
              const suffix = match[3];

              let current = 0;
              const duration = 1500;
              const steps = 40;
              const increment = targetNum / steps;
              const stepTime = duration / steps;

              el.textContent = prefix + "0" + suffix;

              const timer = setInterval(() => {
                current += increment;
                if (current >= targetNum) {
                  current = targetNum;
                  clearInterval(timer);
                }
                const formatted = Math.round(current).toLocaleString("en-US");
                el.textContent = prefix + formatted + suffix;
              }, stepTime);
            });
          },
          { threshold: 0.5 }
        );

        els.forEach((el) => observer.observe(el));

        // Sticky scroll case study animations
        const csContainers = document.querySelectorAll("[data-cs-scroll]");
        if (csContainers.length && window.innerWidth >= 1024) {
          function updateCaseStudies() {
            csContainers.forEach((container) => {
              const rect = container.getBoundingClientRect();
              const scrollHeight = container.clientHeight - window.innerHeight;
              // progress: 0 = section just entered, 1 = fully scrolled through
              const progress = Math.min(Math.max(-rect.top / scrollHeight, 0), 1);

              const heading = container.querySelector(".cs-heading") as HTMLElement | null;
              const text = container.querySelector(".cs-text") as HTMLElement | null;
              const image = container.querySelector(".cs-image") as HTMLElement | null;
              const cards = container.querySelectorAll<HTMLElement>(".cs-card");
              if (!heading) return;

              // Heading: scales 0.7 -> 1 over 0-0.20
              const headingP = Math.min(progress / 0.2, 1);
              heading.style.opacity = "1";
              heading.style.transform = `scale(${0.7 + 0.3 * headingP})`;

              // Text: slides in from left over 0.05-0.40 (overlaps heading)
              if (text) {
                const textP = Math.min(Math.max((progress - 0.05) / 0.35, 0), 1);
                text.style.opacity = String(textP);
                text.style.transform = `translateX(-${60 * (1 - textP)}px)`;
              }

              // Image: slides in from right + unrotates over 0.10-0.45
              if (image) {
                const imgP = Math.min(Math.max((progress - 0.1) / 0.35, 0), 1);
                image.style.opacity = String(imgP);
                image.style.transform = `translateX(${60 * (1 - imgP)}px) rotate(${3 * (1 - imgP)}deg)`;
              }

              // Cards: staggered fade-up; each card animates over 0.30 progress,
              // staggered by 0.07 per index
              cards.forEach((card, i) => {
                const start = 0.05 + i * 0.07;
                const cardP = Math.min(Math.max((progress - start) / 0.3, 0), 1);
                card.style.opacity = String(cardP);
                card.style.transform = `translateY(${40 * (1 - cardP)}px)`;
              });
            });
            requestAnimationFrame(updateCaseStudies);
          }
          requestAnimationFrame(updateCaseStudies);
        }

        // Scroll-linked reveal — adds/removes .revealed based on visibility
        const revealEls = document.querySelectorAll("[data-reveal]");
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
              } else {
                entry.target.classList.remove("revealed");
              }
            });
          },
          { threshold: 0.15 }
        );
        revealEls.forEach((el) => revealObserver.observe(el));

        // Animated underline — play once, stay drawn
        const underlineEls = document.querySelectorAll(".cs-underline-animate");
        const underlineObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
                underlineObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 }
        );
        underlineEls.forEach((el) => underlineObserver.observe(el));

        // Parallax background images
        const parallaxSections = document.querySelectorAll("[data-parallax-bg]");
        if (parallaxSections.length) {
          function updateParallax() {
            parallaxSections.forEach((section) => {
              const rect = section.getBoundingClientRect();
              const img = section.querySelector(".parallax-bg-img") as HTMLElement;
              if (!img) return;
              const speed = 0.3;
              const offset = rect.top * speed;
              img.style.transform = `translateY(${offset}px) scale(1.2)`;
            });
            requestAnimationFrame(updateParallax);
          }
          requestAnimationFrame(updateParallax);
        }
      });
    </script>
  </body>
</html>
