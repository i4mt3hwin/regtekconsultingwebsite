---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { SERVICES, PROOF_STATS } from "../lib/site";

const title = "Healthcare Marketing Services | Google Ads, Meta Ads, Web Design | Regtek";
const description =
  "Google Ads management, Meta Ads management, and conversion-optimized web design for healthcare practices. Founder-led, results-first, small-practice friendly.";
---

<BaseLayout {title} {description}>
  <section class="bg-gray-50 pt-20 pb-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
        How We Help You Grow
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-5 tracking-tight">
        Services Built Around Your Business Goals
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Every healthcare practice is different. Your marketing strategy should be too. We don't do cookie-cutter marketing — every strategy is customized to drive real revenue.
      </p>
    </div>
  </section>

  <section class="bg-[color:var(--color-brand-dark)] py-14">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {PROOF_STATS.map((stat) => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-white">{stat.value}</div>
            <div class="mt-1 text-sm text-gray-200">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-4">Our Services</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Pick what you need, or let us build you a complete system. Every service is designed to generate real revenue.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {SERVICES.map((service) => (
          <article class="bg-white rounded-xl border border-gray-100 shadow-md hover:shadow-xl transition-shadow p-8 flex flex-col">
            <h3 class="text-2xl font-bold text-[color:var(--color-ink)] mb-2">{service.title}</h3>
            <p class="text-sm font-semibold text-[color:var(--color-brand-dark)] mb-4">{service.tagline}</p>
            <p class="text-gray-600 mb-6 flex-1 leading-relaxed">{service.description}</p>
            <a href={service.href} class="inline-flex items-center font-semibold text-[color:var(--color-brand-dark)] hover:text-[color:var(--color-brand-darker)]">
              Learn more →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[color:var(--color-brand-dark)] py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Want to know which services fit your goals?</h2>
      <p class="text-lg text-gray-100 mb-8">Book your free consultation today.</p>
      <a href="/contact" class="inline-flex items-center px-8 py-4 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-colors shadow-lg">
        Book a Free Call →
      </a>
    </div>
  </section>
</BaseLayout>
