---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SocialProof from "../../components/SocialProof.astro";
import { PROOF_STATS, SITE } from "../../lib/site";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

// Related blog posts
const allPosts = await getCollection("posts");
const relatedPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const title = service.data.metaTitle ?? `${service.data.title} | Regtek Consulting`;
const description = service.data.metaDescription ?? service.data.description;

// Split heroHeadline into two balanced halves so it always renders as 2 lines.
// Try each keyword in order; the second half starts with the matched keyword.
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.data.title,
  description: service.data.description,
  url: `${SITE.domain}/services/${service.id}`,
  serviceType: service.data.title,
  provider: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.domain,
  },
  areaServed: {
    "@type": "Country",
    name: "United States",
  },
  audience: {
    "@type": "Audience",
    audienceType: "Healthcare Practices",
  },
};

const headline = service.data.heroHeadline ?? service.data.title;
const splitKeywords = ["Your Best", "Where They", "Into"];
const headlineParts: [string, string] = (() => {
  for (const kw of splitKeywords) {
    const idx = headline.indexOf(kw);
    if (idx >= 0) {
      return [
        headline.slice(0, idx).trim(),
        headline.slice(idx).trim(),
      ];
    }
  }
  return [headline, ""];
})();
---

<BaseLayout {title} {description} extraSchema={serviceSchema}>
  <!-- ========== HERO ========== -->
  <section class="bg-gray-50 pt-10 pb-12 md:pt-20 md:pb-24 overflow-hidden">
    <div class="max-w-[88rem] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[6fr_7fr] gap-10 items-center">
        <div class="lg:order-2">
          <img
            src={service.id === "google-ads" ? "/images/services/google-ads-hero.webp" : service.id === "website-design" ? "/images/services/website-design-hero.webp" : `/images/services/${service.id}-illustration.png`}
            alt={`${service.data.title} illustration`}
            width="640"
            height="420"
            class="w-full h-auto mx-auto max-w-md lg:max-w-none"
            fetchpriority="high"
          />
        </div>
        <div class="lg:order-1 text-center lg:text-left">
          <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
            {service.data.heroEyebrow ?? service.data.title}
          </p>
          <h1 class="text-2xl md:text-4xl lg:text-5xl font-bold leading-[1.15] md:leading-[1.1] text-[color:var(--color-ink)] mb-6 tracking-tight">
            {headlineParts[0]}<br />
            <span class="text-[color:var(--color-brand)]">{headlineParts[1]}</span>
          </h1>
          {service.data.heroSubtitle && (
            <div class="mb-8">
              <p class="font-bold text-[color:var(--color-ink)] mb-3">
                {service.data.heroSubtitle.split('.')[0]}.
              </p>
              <p class="text-gray-800 leading-relaxed">
                {service.data.heroSubtitle.split('.').slice(1).join('.').trim()}
              </p>
            </div>
          )}
          <a
            href="/contact"
            class="inline-flex items-center px-8 py-4 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-all shadow-xl hover:shadow-2xl text-base"
          >
            Book Your Free Consultation Today
          </a>
          <div class="mt-6 flex items-center justify-center lg:justify-start gap-4">
            <SocialProof />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST STRIP ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-14">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-center text-white font-bold text-2xl md:text-3xl mb-10">
        Trusted by growing businesses to generate:
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {PROOF_STATS.map((stat, i) => (
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-[color:var(--color-brand)] text-2xl mb-2">
              {i === 0 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2 12l5 5L20 5" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 17l5-5" /></svg>
              )}
              {i === 1 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              )}
              {i === 2 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" /></svg>
              )}
            </div>
            <div class="text-3xl md:text-4xl font-bold text-[color:var(--color-brand)]" data-countup={stat.value}>{stat.value}</div>
            <div class="mt-1 text-sm text-gray-800">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== MAIN CONTENT ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-6">
      <div class="prose prose-lg max-w-none text-center service-prose">
        <Content />
      </div>
    </div>
  </section>

  <!-- ========== PORTFOLIO (Website Design) ========== -->
  {service.id === "website-design" && (
    <div class="cs-scroll-container" data-cs-scroll>
      <section class="cs-sticky bg-[color:var(--color-brand-dark)] min-h-screen flex items-center overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 w-full py-12">
          <h2 class="cs-heading text-2xl md:text-4xl font-bold text-white text-center mb-4">See Our Latest Projects</h2>
          <div class="flex justify-center mb-14">
            <div class="flex gap-1.5">
              {Array.from({length: 12}).map(() => (
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-300"></div>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
            <a href="https://www.menonmedispa.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:-rotate-1">
                <img src="/images/portfolio/menon-medispa.png" alt="Menon MedSpa website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">Menon MedSpa</span>
                </div>
              </div>
            </a>
            <a href="https://www.psmedgroup.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:rotate-1">
                <img src="/images/portfolio/ps-dermatology.png" alt="PS Dermatology website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">PS Dermatology</span>
                </div>
              </div>
            </a>
            <a href="https://www.psfoot.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:-rotate-1">
                <img src="/images/portfolio/ps-foot-ankle.png" alt="PS Foot & Ankle website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">PS Foot &amp; Ankle</span>
                </div>
              </div>
            </a>
            <a href="https://www.limitlessjointcare.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:rotate-1">
                <img src="/images/portfolio/limitless-spine.png" alt="Limitless Spine & Joint Care website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">Limitless Spine &amp; Joint Care</span>
                </div>
              </div>
            </a>
            <a href="https://www.hfrehabnj.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:-rotate-1">
                <img src="/images/portfolio/health-fitness.png" alt="Health & Fitness Professionals website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">Health &amp; Fitness</span>
                </div>
              </div>
            </a>
            <a href="https://bittner-law.com" target="_blank" rel="noopener" class="cs-card group block">
              <div class="relative overflow-hidden rounded-xl shadow-2xl transition-transform duration-500 group-hover:scale-105 group-hover:rotate-1">
                <img src="/images/portfolio/bittner-law.png" alt="Bittner Law website" width="400" height="600" loading="lazy" class="w-full h-80 object-cover portfolio-img" />
                <div class="absolute bottom-0 left-0 right-0 bg-black/80 py-3 text-center">
                  <span class="text-white font-bold uppercase tracking-wider text-sm">Bittner Law</span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>
    </div>
  )}

  <!-- ========== WE BUILD WEBSITES (Website Design) ========== -->
  {service.id === "website-design" && (
    <section class="bg-gray-100 py-20 md:py-24">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-12">
          <h2 class="text-2xl md:text-4xl font-bold text-[color:var(--color-ink)] mb-4">
            We Build Websites That Actually Work For Your Business
          </h2>
          <p class="text-gray-700 max-w-2xl mx-auto">Most agencies focus on making things look pretty. We focus on making your phone ring and your calendar fill up.</p>
        </div>

        <div class="mb-14">
          <img
            src="/images/services/website-before-after.jpg"
            alt="Medical website conversion optimization: from clutter to conversion - before and after comparison"
            width="768"
            height="419"
            loading="lazy"
            class="w-full h-auto rounded-xl shadow-lg mx-auto"
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Conversion-First Design</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Every pixel has a purpose. We don't just make beautiful websites — we create strategic experiences that guide visitors toward booking, calling, or buying. Form placement, button colors, headline copy — it's all intentional.</p>
          </div>
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Built on Real Data</h3>
            <p class="text-gray-700 text-sm leading-relaxed">We don't guess what works. We use heatmaps, A/B testing, and analytics to see exactly how visitors behave on your site. Then we optimize based on what the data tells us, not what looks trendy.</p>
          </div>
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Continuous Optimization</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Your website isn't a "set it and forget it" project. We monitor performance, test improvements, and make data-driven tweaks to keep your conversion rate climbing month after month.</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ========== META ADS: CASE STUDY + FEATURES ========== -->
  {service.id === "meta-ads" && (
    <div class="cs-scroll-container" data-cs-scroll>
      <section class="cs-sticky bg-[color:var(--color-brand-dark)] min-h-screen flex items-center overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 w-full">
          <h3 class="cs-heading text-3xl md:text-5xl font-bold text-white leading-tight mb-12 text-center">
            Understanding The <br /><span class="cs-underline-animate">Business Model</span>
          </h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="cs-text">
              <h4 class="text-2xl font-bold text-white mb-4">Local MedSpa Achieves 4x Return On Ad Spend</h4>
              <p class="text-lg text-gray-100 leading-relaxed">
                Their Botox ads cost $200 to land a $189 sale. On paper, they were losing money on the first visit and wanted to quit. We dug deeper. We proved that swallowing a small initial loss unlocked the highest retention patients in their database. We stopped chasing cheap leads and started buying high-LTV customers.
              </p>
            </div>
            <div class="cs-image cs-image--down">
              <img
                src="/images/case-studies/medispa-roas-increase.webp"
                alt="MedSpa lifetime value chart showing 4x ROAS"
                width="600"
                height="350"
                loading="lazy"
                class="w-full h-auto rounded-xl shadow-2xl border border-white/10"
              />
            </div>
          </div>
        </div>
      </section>
    </div>
  )}

  {service.id === "meta-ads" && (
    <section class="bg-gray-100 py-20 md:py-24">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="text-2xl md:text-4xl font-bold text-[color:var(--color-ink)] mb-4">Meta Ads That Actually Drive Business Growth</h2>
          <p class="text-gray-700">We don't run ads to get likes and comments. We build campaigns that generate qualified leads, booked appointments, and paying customers.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Precision Audience Targeting</h3>
            <p class="text-gray-700 text-sm leading-relaxed">We build custom audiences based on your ideal customer profile - demographics, interests, behaviors, location, and more. Then we use lookalike audiences to find thousands of people just like your best existing customers. No wasted spend on people who'll never buy.</p>
          </div>
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Scroll-Stopping Creative</h3>
            <p class="text-gray-700 text-sm leading-relaxed">Boring ads get ignored. We create attention-grabbing visuals and copy that stop the scroll and speak directly to your audience's pain points and desires. Every ad is designed to get clicks from qualified prospects, not just passive scrollers.</p>
          </div>
          <div class="bg-white rounded-xl p-8">
            <div class="w-12 h-12 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            </div>
            <h3 class="text-xl font-bold text-[color:var(--color-brand-dark)] mb-3">Conversion-Focused Optimization</h3>
            <p class="text-gray-700 text-sm leading-relaxed">We optimize every campaign for what matters most to your business - booked appointments, form submissions, phone calls, or purchases. Not likes, shares, or comments. We track real conversions and constantly adjust targeting and creative to improve your cost-per-lead.</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ========== META ADS: FAQ ========== -->
  {service.id === "meta-ads" && (
    <section class="bg-gray-200 py-20 md:py-24">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl md:text-4xl font-bold text-[color:var(--color-ink)] mb-10 text-center">
          Common Questions About Our Meta Ads Management
        </h2>
        <div class="space-y-1" data-faq>
          <details class="bg-white rounded-lg group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)]">
              What's the difference between Meta Ads and Facebook Ads?
              <span class="text-[color:var(--color-brand)] text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-800 leading-relaxed">
              Meta Ads is the umbrella term for advertising across Meta's platforms (primarily Facebook and Instagram). When we manage Meta Ads for you, we're running campaigns across both platforms, and sometimes Messenger and Audience Network, to reach your audience wherever they spend time. Most people still call it "Facebook Ads," but it's all under Meta now.
            </div>
          </details>
          <details class="bg-white rounded-lg group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)]">
              How is Meta Ads different from Google Ads?
              <span class="text-[color:var(--color-brand)] text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-800 leading-relaxed">
              Google Ads captures people who are actively searching for your services. Meta Ads reaches people who match your ideal customer profile but may not be actively searching yet. Both are valuable — Google captures demand, Meta creates it. Many businesses benefit from running both.
            </div>
          </details>
          <details class="bg-white rounded-lg group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)]">
              How much should I budget for Meta Ads?
              <span class="text-[color:var(--color-brand)] text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-800 leading-relaxed">
              It depends on your market, your goals, and your customer lifetime value. We'll help you determine the right budget during our consultation based on your specific business economics.
            </div>
          </details>
          <details class="bg-white rounded-lg group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)]">
              Do you only work with healthcare businesses?
              <span class="text-[color:var(--color-brand)] text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-800 leading-relaxed">
              Healthcare is our deepest expertise, but we work with service-based businesses across industries. The principles of precision targeting, conversion optimization, and lifetime value measurement apply universally.
            </div>
          </details>
          <details class="bg-white rounded-lg group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-[color:var(--color-ink)] hover:text-[color:var(--color-brand-dark)]">
              How quickly will I see results?
              <span class="text-[color:var(--color-brand)] text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="px-5 pb-5 text-sm text-gray-800 leading-relaxed">
              Meta Ads can start generating leads within the first 1-2 weeks. The learning phase typically takes 7-14 days as the algorithm optimizes delivery. Meaningful performance data comes at 30-60 days, and campaigns continue improving over time as we refine targeting and creative.
            </div>
          </details>
        </div>
      </div>
    </section>
  )}

