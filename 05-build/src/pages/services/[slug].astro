  <!-- ========== RELATED POSTS ========== -->
  {relatedPosts.length > 0 && (
    <section class="bg-gray-100 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-[color:var(--color-ink)] mb-8 text-center">
          Related Reading
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6 block"
