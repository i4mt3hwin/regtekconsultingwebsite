---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, TESTIMONIAL } from "../lib/site";

const title = "About Regtek Consulting | Founder-Led Marketing Agency";
const description = "No account managers or hand-offs. Work directly with a founder who's scaled businesses to Inc 5000. Learn the story behind Regtek Consulting.";

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Regtek Consulting",
  mainEntity: {
    "@type": "Person",
    name: "Kevin Dillon",
    jobTitle: "Founder",
    worksFor: {
      "@type": "Organization",
      name: "Regtek Consulting",
      url: SITE.domain,
    },
    knowsAbout: ["Healthcare Marketing", "Google Ads", "Meta Ads", "Conversion Rate Optimization"],
  },
};
---

<BaseLayout {title} {description} extraSchema={aboutSchema}>
  <!-- ========== HERO ========== -->
  <section class="bg-gray-50 pt-16 pb-20 md:pt-20 md:pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-first">
          <img
            src="/images/hero/kevin-reggie-selfie.jpg"
            alt="Kevin Dillon with his dog Reggie"
            width="768"
            height="1024"
            class="w-full h-auto rounded-2xl shadow-xl"
            fetchpriority="high"
          />
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">About Regtek</p>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-[1.1] text-[color:var(--color-ink)] mb-6 tracking-tight">
            From Healthcare Operations To Digital Marketing
          </h1>
          <div class="space-y-4 text-gray-800 leading-relaxed">
            <p>Hi, I'm Kevin. Before I ran digital marketing campaigns, I ran operations for a healthcare clinic that grew from a single location to five offices and achieved Inc 5000 recognition.</p>
            <p>Here's what I learned during that journey: marketing isn't just about getting clicks. It's about understanding your entire business model, your operations, your capacity, your customer lifetime value, and your growth constraints.</p>
            <p>Most agencies don't think about those things. They optimize for conversions without asking if you can handle more customers. They run ads without understanding your margins. They chase vanity metrics instead of revenue.</p>
            <p class="font-semibold text-[color:var(--color-ink)]">That's why I started Regtek. To bring operational expertise to digital marketing. To be a true strategic partner, not just an ad buyer.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHAT I BRING ========== -->
  <section class="bg-white py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-4 leading-tight">
          What I Bring To Your Business
        </h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">
          A unique combination of operational experience, digital marketing expertise, and technical skills.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Healthcare Operations Experience -->
        <div class="bg-gray-50 rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[color:var(--color-brand)]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-4">Healthcare Operations Experience</h3>
          <ul class="space-y-2.5 text-gray-800">
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Scaled clinic from 1 to 5 locations</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Achieved Inc 5000 fastest-growing company recognition</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Deep understanding of medical practice economics</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Patient lifetime value optimization</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Operational constraints and capacity planning</span></li>
          </ul>
        </div>

        <!-- Digital Marketing Expertise -->
        <div class="bg-gray-50 rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[color:var(--color-brand)]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-4">Digital Marketing Expertise</h3>
          <ul class="space-y-2.5 text-gray-800">
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Google Ads management and optimization</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Meta Ads strategy and execution</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Website design and conversion rate optimization</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Advanced tracking and attribution modeling</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Multi-channel campaign coordination</span></li>
          </ul>
        </div>

        <!-- Technical Skills -->
        <div class="bg-gray-50 rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[color:var(--color-brand)]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-4">Technical Skills</h3>
          <ul class="space-y-2.5 text-gray-800">
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Custom domain and email setup</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Web hosting, security, and SSL certificates</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Google Business Profile optimization</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Call tracking and analytics integration</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>HIPAA-compliant marketing infrastructure</span></li>
          </ul>
        </div>

        <!-- Strategic Consulting -->
        <div class="bg-gray-50 rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-xl bg-[color:var(--color-brand)]/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-4">Strategic Consulting</h3>
          <ul class="space-y-2.5 text-gray-800">
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Business model optimization</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Pricing strategy development</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Customer acquisition cost analysis</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Lifetime value maximization strategies</span></li>
            <li class="flex items-start gap-3"><span class="text-[color:var(--color-brand)] font-bold mt-0.5">&#10003;</span><span>Growth constraint identification and solutions</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIAL ========== -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="text-[color:var(--color-brand)] text-6xl font-serif leading-none mb-4">&ldquo;</div>
      <blockquote class="text-xl md:text-2xl font-medium text-[color:var(--color-ink)] leading-snug">
        {TESTIMONIAL.quote}
      </blockquote>
      <div class="mt-6">
        <div class="font-bold text-[color:var(--color-ink)]">{TESTIMONIAL.author}</div>
        <div class="text-sm text-gray-700">{TESTIMONIAL.role}</div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
        Let's Talk About Your Practice
      </h2>
      <p class="text-lg text-gray-100 mb-10 max-w-2xl mx-auto">
        Book a free consultation. We'll dig into your business, your goals, and whether Regtek is the right fit.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl text-base"
      >
        Book a Free Consultation
      </a>
    </div>
  </section>
</BaseLayout>
