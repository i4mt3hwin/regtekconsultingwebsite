---
export const prerender = true;

import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSiteSettings } from "../../lib/content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const site = getSiteSettings();

const CATEGORY_LABELS: Record<string, string> = {
  "case-studies-results": "Case Studies & Results",
  "website-conversion-optimization": "Website & Conversion Optimization",
  general: "General",
};

// Related posts: same category, excluding this one, max 3
const allPosts = await getCollection("posts");
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const title = post.data.metaTitle ?? `${post.data.title} | Regtek Consulting`;
const description = post.data.metaDescription ?? post.data.excerpt;

// Article schema for SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Kevin Dillon",
    url: "https://www.regtekconsulting.com/about",
  },
  publisher: {
    "@type": "Organization",
    name: "Regtek Consulting",
    logo: {
      "@type": "ImageObject",
      url: "https://www.regtekconsulting.com/images/brand/regtek-logo.png",
    },
  },
  description: post.data.excerpt,
  mainEntityOfPage: `https://www.regtekconsulting.com/blog/${post.id}`,
};

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout {title} {description} extraSchema={articleSchema}>
  <article>
    <!-- Header -->
    <section class="bg-gray-50 pt-20 pb-14">
      <div class="max-w-3xl mx-auto px-6">
        <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[color:var(--color-brand-dark)]">Home</a>
          <span class="mx-2">›</span>
          <a href="/blog" class="hover:text-[color:var(--color-brand-dark)]">Blog</a>
          <span class="mx-2">›</span>
          <a href={`/blog/category/${post.data.category}`} class="hover:text-[color:var(--color-brand-dark)]">
            {CATEGORY_LABELS[post.data.category] ?? post.data.category}
          </a>
        </nav>
        <p class="text-xs font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
          {CATEGORY_LABELS[post.data.category] ?? post.data.category}
        </p>
        <h1 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-6 leading-tight tracking-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-gray-500">
          <span>By <strong class="text-[color:var(--color-ink)]">Kevin Dillon</strong></span>
          <span>·</span>
          <time datetime={post.data.publishDate.toISOString()}>
            {formatDate(post.data.publishDate)}
          </time>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="bg-white py-16">
      <div class="max-w-3xl mx-auto px-6">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        <!-- Author / CTA footer -->
        <div class="mt-16 pt-10 border-t border-gray-200">
          <div class="bg-gray-50 rounded-2xl p-8 md:p-10">
            <h2 class="text-2xl font-bold text-[color:var(--color-ink)] mb-3">
              Want this applied to your practice?
            </h2>
            <p class="text-gray-700 mb-6">
              I'm Kevin Dillon — founder of Regtek. I've scaled healthcare businesses to Inc 5000 status and now help other practices do the same. Let's talk about what would move the needle for yours.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center px-6 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors shadow-sm"
            >
              Book a Free Consultation →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Related -->
    {related.length > 0 && (
      <section class="bg-gray-100 py-16">
        <div class="max-w-6xl mx-auto px-6">
          <h2 class="text-2xl md:text-3xl font-bold text-[color:var(--color-ink)] mb-8 text-center">
            More from {CATEGORY_LABELS[post.data.category] ?? post.data.category}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {related.map((r) => (
              <a
                href={`/blog/${r.id}`}
                class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-6 block"
              >
                <h3 class="text-lg font-bold text-[color:var(--color-ink)] mb-2 leading-snug">
                  {r.data.title}
                </h3>
                <p class="text-sm text-gray-600 line-clamp-3">{r.data.excerpt}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
