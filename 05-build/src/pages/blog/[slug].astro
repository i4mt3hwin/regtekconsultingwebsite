---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const CATEGORY_LABELS: Record<string, string> = {
  "case-studies-results": "Case Studies & Results",
  "website-conversion-optimization": "Website & Conversion Optimization",
  general: "General",
};

// All posts sorted by date for prev/next navigation
const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

// Related posts — same category first, then others, max 3
const sameCategory = allPosts.filter((p) => p.id !== post.id && p.data.category === post.data.category);
const otherPosts = allPosts.filter((p) => p.id !== post.id && p.data.category !== post.data.category);
const relatedPosts = [...sameCategory, ...otherPosts].slice(0, 3);

const title = post.data.metaTitle ?? `${post.data.title} | Regtek Consulting`;
const description = post.data.metaDescription ?? post.data.excerpt;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Kevin Dillon",
    url: "https://www.regtekconsulting.com/about",
  },
  publisher: {
    "@type": "Organization",
    name: "Regtek Consulting",
    logo: {
      "@type": "ImageObject",
      url: "https://www.regtekconsulting.com/images/brand/regtek-logo.png",
    },
  },
  description: post.data.excerpt,
  mainEntityOfPage: `https://www.regtekconsulting.com/blog/${post.id}`,
};

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout {title} {description} extraSchema={articleSchema}>
  <article>
    <!-- ========== HERO — magazine split ========== -->
    <section class="relative overflow-hidden bg-gradient-to-b from-blue-50 via-white to-white pt-10 pb-16 md:pt-14 md:pb-20">
      <!-- Soft brand-tinted accent in the corner -->
      <div aria-hidden="true" class="pointer-events-none absolute -top-40 -right-40 w-[680px] h-[680px] rounded-full bg-[radial-gradient(closest-side,rgba(6,182,212,0.20),transparent)] blur-2xl"></div>

      <div class="relative max-w-[88rem] mx-auto px-6 md:px-10">
        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-500 mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[color:var(--color-brand-dark)]">Home</a>
          <span class="mx-2">&rsaquo;</span>
          <a href="/blog" class="hover:text-[color:var(--color-brand-dark)]">Tips & Tricks</a>
          <span class="mx-2">&rsaquo;</span>
          <a href={`/blog/category/${post.data.category}`} class="hover:text-[color:var(--color-brand-dark)]">
            {CATEGORY_LABELS[post.data.category] ?? post.data.category}
          </a>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-[7fr_5fr] gap-10 lg:gap-16 items-center">
          <!-- Text column -->
          <div>
            <!-- Category badge -->
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-[color:var(--color-brand)]/15 text-[color:var(--color-brand-darker)] mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--color-brand-dark)]"></span>
              {CATEGORY_LABELS[post.data.category] ?? post.data.category}
            </span>

            <!-- Title -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[color:var(--color-ink)] mb-6 leading-[1.05] tracking-tight">
              {post.data.title}
            </h1>

            <!-- Deck / excerpt -->
            {post.data.excerpt && (
              <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl">
                {post.data.excerpt}
              </p>
            )}

            <!-- Author meta row -->
            <div class="flex items-center gap-4 pt-2">
              <div class="w-11 h-11 rounded-full bg-[color:var(--color-brand-dark)] flex items-center justify-center text-white font-bold text-sm shadow-md">
                KD
              </div>
              <div>
                <div class="text-sm font-semibold text-[color:var(--color-ink)]">Kevin Dillon</div>
                <div class="flex items-center gap-2 text-xs text-gray-500">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  <span>&bull;</span>
                  <span>5 min read</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Image column -->
          {post.data.heroImage && (
            <div class="relative">
              <!-- Soft cyan glow behind the image -->
              <div aria-hidden="true" class="absolute -inset-6 bg-gradient-to-br from-[color:var(--color-brand)]/25 via-[color:var(--color-brand-dark)]/10 to-transparent rounded-[2rem] blur-2xl -z-10"></div>
              <div class="relative rounded-2xl overflow-hidden shadow-2xl ring-1 ring-black/5">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  width="720"
                  height="540"
                  class="w-full h-auto"
                  fetchpriority="high"
                />
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ========== CONTENT + SIDEBAR (two-column on lg+) ========== -->
    <section class="bg-white py-14 md:py-16">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-10 lg:gap-16">

          <!-- Main content column -->
          <div class="min-w-0" data-blog-article>
            <div class="max-w-[52rem]">
              <!-- Mobile-only collapsible ToC -->
              <details class="lg:hidden mb-8 blog-toc-mobile">
                <summary>
                  <span>On This Page</span>
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </summary>
                <ul data-toc-list-mobile></ul>
              </details>

              <div class="prose prose-lg max-w-none">
                <Content />
              </div>
            </div>
          </div>

          <!-- Sticky sidebar (desktop only) -->
          <aside class="hidden lg:block">
            <div class="sticky top-40 space-y-8">
              <!-- Table of contents -->
              <nav class="blog-toc" aria-label="Table of contents" data-toc-root>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">On This Page</div>
                <ul data-toc-list class="space-y-1.5 text-sm"></ul>
              </nav>

              <!-- CTA card -->
              <div class="bg-gray-50 rounded-xl p-6 border border-gray-200">
                <div class="w-11 h-11 rounded-full bg-[color:var(--color-brand-dark)] flex items-center justify-center text-white font-bold text-sm mb-4">
                  KD
                </div>
                <h3 class="font-bold text-[color:var(--color-ink)] mb-2 leading-snug">Ready to see results for your practice?</h3>
                <p class="text-sm text-gray-600 mb-5 leading-relaxed">
                  30-minute strategy call. Straight to Kevin, no account managers.
                </p>
                <a
                  href="/contact"
                  class="inline-flex justify-center items-center w-full px-4 py-2.5 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors"
                >
                  Book a Free Consultation
                </a>
              </div>

              <!-- Related posts list -->
              {relatedPosts.length > 0 && (
                <div class="pt-2 border-t border-gray-200">
                  <div class="text-xs font-semibold uppercase tracking-wider text-gray-500 mt-6 mb-4">More Tips & Tricks</div>
                  <ul class="space-y-4">
                    {relatedPosts.map((r) => (
                      <li>
                        <a href={`/blog/${r.id}`} class="group block">
                          <h4 class="text-sm font-semibold text-[color:var(--color-ink)] group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-3 transition-colors">
                            {r.data.title}
                          </h4>
                          <time datetime={r.data.publishDate.toISOString()} class="block mt-1 text-xs text-gray-500">
                            {formatDate(r.data.publishDate)}
                          </time>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- ========== MOBILE-ONLY AUTHOR CTA (shown below content on mobile, sidebar handles desktop) ========== -->
    <section class="lg:hidden bg-white py-10">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10">
        <div class="bg-gray-50 rounded-2xl p-8 md:p-10 flex flex-col md:flex-row gap-6 items-start border border-gray-200">
          <div class="flex-shrink-0 w-16 h-16 rounded-full bg-[color:var(--color-brand-dark)] flex items-center justify-center text-white font-bold text-xl">
            KD
          </div>
          <div>
            <h2 class="text-2xl font-bold text-[color:var(--color-ink)] mb-2">
              Ready to see results for your practice?
            </h2>
            <p class="text-gray-600 mb-5 leading-relaxed">
              30-minute strategy call. Direct access to Kevin Dillon, the founder who's scaled healthcare businesses to Inc 5000. No account managers, no pitch deck, just answers.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center px-7 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors shadow-sm"
            >
              Book a Free Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== PREV / NEXT NAV ========== -->
    <section class="bg-gray-50 py-8">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10 grid grid-cols-1 md:grid-cols-2 gap-4">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-[color:var(--color-brand)] hover:shadow-md transition-all">
            <span class="text-xs text-gray-400 uppercase tracking-wider">&larr; Previous</span>
            <p class="text-sm font-semibold text-[color:var(--color-ink)] mt-1 group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-2">
              {prevPost.data.title}
            </p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`} class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-[color:var(--color-brand)] hover:shadow-md transition-all text-right">
            <span class="text-xs text-gray-400 uppercase tracking-wider">Next &rarr;</span>
            <p class="text-sm font-semibold text-[color:var(--color-ink)] mt-1 group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-2">
              {nextPost.data.title}
            </p>
          </a>
        ) : <div />}
      </div>
    </section>

    <!-- ========== MOBILE-ONLY RELATED POSTS GRID ========== -->
    {relatedPosts.length > 0 && (
      <section class="lg:hidden bg-white py-14">
        <div class="max-w-[88rem] mx-auto px-6 md:px-10">
          <h2 class="text-2xl md:text-3xl font-bold text-[color:var(--color-ink)] mb-8 text-center">
            More Tips & Tricks
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map((r) => (
              <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
                {r.data.heroImage && (
                  <img
                    src={r.data.heroImage}
                    alt={r.data.title}
                    width="400"
                    height="200"
                    loading="lazy"
                    class="w-full h-40 object-cover"
                  />
                )}
                <div class="p-5 flex-1 flex flex-col">
                  <h3 class="text-base font-bold text-[color:var(--color-ink)] mb-2 leading-snug">
                    <a href={`/blog/${r.id}`} class="hover:text-[color:var(--color-brand-dark)]">
                      {r.data.title}
                    </a>
                  </h3>
                  <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">
                    {r.data.excerpt}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  // Build ToC from H2/H3 inside the article prose, set ids, wire up active-section highlighting.
  (() => {
    const article = document.querySelector<HTMLElement>("[data-blog-article]");
    if (!article) return;

    const headings = Array.from(
      article.querySelectorAll<HTMLHeadingElement>(".prose h2, .prose h3"),
    );
    if (!headings.length) return;

    const slugify = (text: string) =>
      text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");

    const usedIds = new Set<string>();
    const items = headings.map((h) => {
      let id = h.id;
      if (!id) {
        const base = slugify(h.textContent || "");
        id = base;
        let suffix = 2;
        while (usedIds.has(id) || document.getElementById(id)) {
          id = `${base}-${suffix++}`;
        }
        h.id = id;
      }
      usedIds.add(id);
      return {
        id,
        text: h.textContent?.trim() ?? "",
        level: h.tagName === "H2" ? 2 : 3,
      };
    });

    const renderInto = (list: HTMLElement | null) => {
      if (!list) return;
      list.innerHTML = items
        .map(
          (item) =>
            `<li class="toc-item toc-level-${item.level}"><a href="#${item.id}" data-toc-link="${item.id}" class="toc-link">${item.text}</a></li>`,
        )
        .join("");
    };
    renderInto(document.querySelector<HTMLElement>("[data-toc-list]"));
    renderInto(document.querySelector<HTMLElement>("[data-toc-list-mobile]"));

    // Active-section highlighting
    const allLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
    );
    let activeId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === activeId) return;
      allLinks.forEach((link) => {
        link.classList.toggle(
          "toc-active",
          !!id && link.dataset.tocLink === id,
        );
      });
      activeId = id;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // Track which headings are currently above the 25%-from-top line
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length) {
          // Pick the one closest to the top of the viewport
          const closest = visible.reduce((best, cur) =>
            cur.boundingClientRect.top < best.boundingClientRect.top ? cur : best,
          );
          setActive(closest.target.id);
        }
      },
      {
        rootMargin: "-80px 0px -60% 0px",
        threshold: 0,
      },
    );
    headings.forEach((h) => observer.observe(h));
  })();
</script>
