---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const CATEGORY_LABELS: Record<string, string> = {
  "case-studies-results": "Case Studies & Results",
  "website-conversion-optimization": "Website & Conversion Optimization",
  general: "General",
};

// All posts sorted by date for prev/next navigation
const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

// Related posts — same category first, then others, max 3
const sameCategory = allPosts.filter((p) => p.id !== post.id && p.data.category === post.data.category);
const otherPosts = allPosts.filter((p) => p.id !== post.id && p.data.category !== post.data.category);
const relatedPosts = [...sameCategory, ...otherPosts].slice(0, 3);

const title = post.data.metaTitle ?? `${post.data.title} | Regtek Consulting`;
const description = post.data.metaDescription ?? post.data.excerpt;

// Estimated read time from the raw markdoc body
const wordCount = ((post.body ?? "").match(/\S+/g) ?? []).length;
const readMinutes = Math.max(1, Math.round(wordCount / 200));

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: post.data.publishDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Kevin Dillon",
    url: `${SITE.domain}/about`,
  },
  publisher: {
    "@type": "Organization",
    name: "Regtek Consulting",
    logo: {
      "@type": "ImageObject",
      url: `${SITE.domain}/images/brand/regtek-logo.png`,
    },
  },
  description: post.data.excerpt,
  mainEntityOfPage: `${SITE.domain}/blog/${post.id}`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: SITE.domain,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Tips & Tricks",
      item: `${SITE.domain}/blog`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: `${SITE.domain}/blog/${post.id}`,
    },
  ],
};

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout {title} {description} extraSchema={[articleSchema, breadcrumbSchema]}>
  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true"><span data-reading-progress></span></div>

  <article>
    <!-- ========== HERO — magazine split with branded gradient + dot grid ========== -->
    <section class="blog-hero relative overflow-hidden pt-8 pb-12 md:pt-16 md:pb-28">
      <!-- Layered backdrop -->
      <div aria-hidden="true" class="blog-hero-bg"></div>
      <div aria-hidden="true" class="blog-hero-grid"></div>
      <div aria-hidden="true" class="blog-hero-glow blog-hero-glow--right"></div>
      <div aria-hidden="true" class="blog-hero-glow blog-hero-glow--left"></div>

      <div class="relative max-w-[88rem] mx-auto px-6 md:px-10">
        <!-- Breadcrumb -->
        <nav class="text-sm text-gray-700 mb-8 text-center lg:text-left" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[color:var(--color-brand-dark)]">Home</a>
          <span class="mx-2 text-gray-400">&rsaquo;</span>
          <a href="/blog" class="hover:text-[color:var(--color-brand-dark)]">Tips & Tricks</a>
          <span class="mx-2 text-gray-400">&rsaquo;</span>
          <a href={`/blog/category/${post.data.category}`} class="hover:text-[color:var(--color-brand-dark)]">
            {CATEGORY_LABELS[post.data.category] ?? post.data.category}
          </a>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-[7fr_5fr] gap-10 lg:gap-16 items-center">
          <!-- Text column -->
          <div class="text-center lg:text-left">
            <!-- Category badge -->
            <span data-reveal="up" class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-[0.14em] bg-white/80 backdrop-blur-sm text-[color:var(--color-brand-darker)] mb-7 ring-1 ring-[color:var(--color-brand)]/30 shadow-sm">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[color:var(--color-brand)] opacity-60"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-[color:var(--color-brand-dark)]"></span>
              </span>
              {CATEGORY_LABELS[post.data.category] ?? post.data.category}
            </span>

            <!-- Title -->
            <h1 data-reveal="up" data-reveal-delay="1" class="blog-hero-title text-3xl md:text-5xl lg:text-[3.75rem] font-extrabold text-[color:var(--color-ink)] mb-5 md:mb-7 leading-[1.1] md:leading-[1.05] tracking-tight">
              {post.data.title}
            </h1>

            <!-- Deck / excerpt -->
            {post.data.excerpt && (
              <p data-reveal="up" data-reveal-delay="2" class="text-base md:text-xl text-gray-700 mb-7 md:mb-9 leading-relaxed max-w-2xl mx-auto lg:mx-0">
                {post.data.excerpt}
              </p>
            )}

            <!-- Author meta row -->
            <div data-reveal="up" data-reveal-delay="3" class="flex items-center justify-center lg:justify-start gap-4 pt-2">
              <div class="blog-author-avatar">
                <div class="blog-author-avatar-inner">KD</div>
              </div>
              <div>
                <div class="text-sm font-semibold text-[color:var(--color-ink)]">Kevin Dillon <span class="text-gray-500 font-normal">— Founder</span></div>
                <div class="flex items-center gap-2 text-xs text-gray-700 mt-0.5">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {formatDate(post.data.publishDate)}
                  </time>
                  <span class="text-gray-400">&bull;</span>
                  <span class="inline-flex items-center gap-1">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {readMinutes} min read
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Image column -->
          {post.data.heroImage && (
            <div data-reveal="right" class="relative blog-hero-figure">
              <!-- Decorative offset accent -->
              <div aria-hidden="true" class="blog-hero-figure-accent"></div>
              <!-- Soft cyan glow behind the image -->
              <div aria-hidden="true" class="absolute -inset-8 bg-gradient-to-br from-[color:var(--color-brand)]/30 via-[color:var(--color-brand-dark)]/15 to-transparent rounded-[2rem] blur-3xl -z-10"></div>
              <div class="relative rounded-2xl overflow-hidden shadow-2xl ring-1 ring-black/10">
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  width="720"
                  height="540"
                  class="w-full h-auto"
                  fetchpriority="high"
                />
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ========== CONTENT + SIDEBAR (two-column on lg+) ========== -->
    <section class="bg-white py-14 md:py-16">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_320px] gap-10 lg:gap-16">

          <!-- Main content column -->
          <div class="min-w-0" data-blog-article>
            <div class="max-w-[52rem]">
              <!-- Mobile-only collapsible ToC -->
              <details class="lg:hidden mb-8 blog-toc-mobile">
                <summary>
                  <span>On This Page</span>
                  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </summary>
                <ul data-toc-list-mobile></ul>
              </details>

              <div class="prose prose-lg max-w-none blog-prose">
                <Content />
              </div>
            </div>
          </div>

          <!-- Sticky sidebar (desktop only) -->
          <aside class="hidden lg:block">
            <div class="sticky top-40 space-y-8">
              <!-- Table of contents -->
              <nav class="blog-toc" aria-label="Table of contents" data-toc-root>
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-700 mb-4">On This Page</div>
                <ul data-toc-list class="space-y-1.5 text-sm"></ul>
              </nav>

              <!-- CTA card — brand gradient, premium feel -->
              <div class="blog-cta-card relative overflow-hidden rounded-2xl p-6 text-white shadow-lg">
                <div aria-hidden="true" class="blog-cta-card-glow"></div>
                <div class="relative">
                  <div class="w-12 h-12 rounded-full bg-white/15 ring-2 ring-white/40 flex items-center justify-center text-white font-bold text-sm mb-4 backdrop-blur-sm">
                    KD
                  </div>
                  <h3 class="font-bold text-white mb-2 leading-snug text-base">Ready to see results for your practice?</h3>
                  <p class="text-sm text-white/90 mb-5 leading-relaxed">
                    30-minute strategy call. Straight to Kevin, no account managers.
                  </p>
                  <a
                    href="/contact"
                    class="inline-flex justify-center items-center w-full px-4 py-2.5 bg-white text-[color:var(--color-brand-darker)] font-semibold text-sm rounded-md hover:bg-gray-50 transition-all hover:-translate-y-0.5 hover:shadow-md"
                  >
                    Book a Free Consultation
                  </a>
                </div>
              </div>

              <!-- Related posts list -->
              {relatedPosts.length > 0 && (
                <div class="pt-2 border-t border-gray-200">
                  <div class="text-xs font-semibold uppercase tracking-wider text-gray-700 mt-6 mb-4">More Tips & Tricks</div>
                  <ul class="space-y-4">
                    {relatedPosts.map((r) => (
                      <li>
                        <a href={`/blog/${r.id}`} class="group block">
                          <h4 class="text-sm font-semibold text-[color:var(--color-ink)] group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-3 transition-colors">
                            {r.data.title}
                          </h4>
                          <time datetime={r.data.publishDate.toISOString()} class="block mt-1 text-xs text-gray-700">
                            {formatDate(r.data.publishDate)}
                          </time>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- ========== MOBILE-ONLY AUTHOR CTA (shown below content on mobile, sidebar handles desktop) ========== -->
    <section class="lg:hidden bg-white py-10">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10">
        <div class="blog-cta-card-lg relative overflow-hidden rounded-2xl p-8 md:p-10 flex flex-col md:flex-row gap-6 items-start text-white shadow-xl">
          <div aria-hidden="true" class="blog-cta-card-glow"></div>
          <div class="relative flex-shrink-0 w-16 h-16 rounded-full bg-white/15 ring-2 ring-white/40 flex items-center justify-center text-white font-bold text-xl backdrop-blur-sm">
            KD
          </div>
          <div class="relative">
            <h2 class="text-2xl font-bold text-white mb-2">
              Ready to see results for your practice?
            </h2>
            <p class="text-white/90 mb-5 leading-relaxed">
              30-minute strategy call. Direct access to Kevin Dillon, the founder who's scaled healthcare businesses to Inc 5000. No account managers, no pitch deck, just answers.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center px-7 py-3 bg-white text-[color:var(--color-brand-darker)] font-semibold rounded-md hover:bg-gray-50 transition-all hover:-translate-y-0.5 shadow-sm hover:shadow-md"
            >
              Book a Free Consultation
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== PREV / NEXT NAV ========== -->
    <section class="bg-gradient-to-b from-white to-gray-50 py-12">
      <div class="max-w-[88rem] mx-auto px-6 md:px-10 grid grid-cols-1 md:grid-cols-2 gap-4">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="prev-next-card group bg-white rounded-xl border border-gray-200 p-6 transition-all">
            <span class="prev-next-label inline-flex items-center gap-1.5 text-xs text-gray-500 uppercase tracking-[0.14em] font-semibold">
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="prev-next-arrow"><path d="M12.5 5L7.5 10L12.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Previous
            </span>
            <p class="text-base font-bold text-[color:var(--color-ink)] mt-2 group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-2 transition-colors">
              {prevPost.data.title}
            </p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`} class="prev-next-card prev-next-card--right group bg-white rounded-xl border border-gray-200 p-6 transition-all text-right">
            <span class="prev-next-label inline-flex items-center gap-1.5 text-xs text-gray-500 uppercase tracking-[0.14em] font-semibold">
              Next
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="prev-next-arrow"><path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <p class="text-base font-bold text-[color:var(--color-ink)] mt-2 group-hover:text-[color:var(--color-brand-dark)] leading-snug line-clamp-2 transition-colors">
              {nextPost.data.title}
            </p>
          </a>
        ) : <div />}
      </div>
    </section>

    <!-- ========== MOBILE-ONLY RELATED POSTS GRID ========== -->
    {relatedPosts.length > 0 && (
      <section class="lg:hidden bg-white py-14">
        <div class="max-w-[88rem] mx-auto px-6 md:px-10">
          <h2 class="text-2xl md:text-3xl font-bold text-[color:var(--color-ink)] mb-8 text-center">
            More Tips & Tricks
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedPosts.map((r) => (
              <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
                {r.data.heroImage && (
                  <img
                    src={r.data.heroImage}
                    alt={r.data.title}
                    width="400"
                    height="200"
                    loading="lazy"
                    class="w-full h-40 object-cover"
                  />
                )}
                <div class="p-5 flex-1 flex flex-col">
                  <h3 class="text-base font-bold text-[color:var(--color-ink)] mb-2 leading-snug">
                    <a href={`/blog/${r.id}`} class="hover:text-[color:var(--color-brand-dark)]">
                      {r.data.title}
                    </a>
                  </h3>
                  <p class="text-sm text-gray-800 leading-relaxed line-clamp-3">
                    {r.data.excerpt}
                  </p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<script>
  // Build ToC from H2/H3 inside the article prose, set ids, wire up active-section highlighting.
  (() => {
    const article = document.querySelector<HTMLElement>("[data-blog-article]");
    if (!article) return;

    const headings = Array.from(
      article.querySelectorAll<HTMLHeadingElement>(".prose h2, .prose h3"),
    );
    if (!headings.length) return;

    const slugify = (text: string) =>
      text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-")
        .replace(/-+/g, "-");

    const usedIds = new Set<string>();
    const items = headings.map((h) => {
      let id = h.id;
      if (!id) {
        const base = slugify(h.textContent || "");
        id = base;
        let suffix = 2;
        while (usedIds.has(id) || document.getElementById(id)) {
          id = `${base}-${suffix++}`;
        }
        h.id = id;
      }
      usedIds.add(id);
      return {
        id,
        text: h.textContent?.trim() ?? "",
        level: h.tagName === "H2" ? 2 : 3,
      };
    });

    const renderInto = (list: HTMLElement | null) => {
      if (!list) return;
      list.innerHTML = items
        .map(
          (item) =>
            `<li class="toc-item toc-level-${item.level}"><a href="#${item.id}" data-toc-link="${item.id}" class="toc-link">${item.text}</a></li>`,
        )
        .join("");
    };
    renderInto(document.querySelector<HTMLElement>("[data-toc-list]"));
    renderInto(document.querySelector<HTMLElement>("[data-toc-list-mobile]"));

    // Active-section highlighting
    const allLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
    );
    let activeId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === activeId) return;
      allLinks.forEach((link) => {
        link.classList.toggle(
          "toc-active",
          !!id && link.dataset.tocLink === id,
        );
      });
      activeId = id;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        // Track which headings are currently above the 25%-from-top line
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length) {
          // Pick the one closest to the top of the viewport
          const closest = visible.reduce((best, cur) =>
            cur.boundingClientRect.top < best.boundingClientRect.top ? cur : best,
          );
          setActive(closest.target.id);
        }
      },
      {
        rootMargin: "-80px 0px -60% 0px",
        threshold: 0,
      },
    );
    headings.forEach((h) => observer.observe(h));
  })();

  // Reading progress bar — tracks scroll through the article body
  (() => {
    const bar = document.querySelector<HTMLElement>("[data-reading-progress]");
    const article = document.querySelector<HTMLElement>("[data-blog-article]");
    if (!bar || !article) return;

    let ticking = false;
    const update = () => {
      const rect = article.getBoundingClientRect();
      const viewport = window.innerHeight;
      // Total scrollable distance over the article
      const total = rect.height - viewport;
      const scrolled = -rect.top;
      const progress = total > 0 ? Math.min(100, Math.max(0, (scrolled / total) * 100)) : 0;
      bar.style.width = `${progress}%`;
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  })();
</script>
