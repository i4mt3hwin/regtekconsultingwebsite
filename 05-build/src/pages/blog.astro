---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SERVICES } from "../lib/site";

const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);

// Featured = latest post (list is already sorted newest-first above)
const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1);

const CATEGORY_LABELS: Record<string, string> = {
  "case-studies-results": "Case Studies & Results",
  "website-conversion-optimization": "Website & Conversion Optimization",
  general: "General",
};

const title = "Marketing Tips & Tricks | Regtek Consulting";
const description = "No jargon, no filler. Just actionable marketing tips to help you get better results from your ads and website. Browse our latest posts.";

function formatDate(d: Date): string {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout {title} {description}>
  <!-- ========== HERO ========== -->
  <section class="bg-blue-50 py-14 md:py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-5 tracking-tight">
        Tips & Tricks That Actually Work
      </h1>
      <p class="text-lg text-gray-800 max-w-3xl mx-auto">
        Data-driven marketing insights, PPC strategies, and business growth tactics from the field. No fluff, no jargon. Just proven strategies you can use today.
      </p>
    </div>
  </section>

  <!-- ========== FEATURED + SIDEBAR ========== -->
  <section class="bg-white py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Featured Post -->
        <div class="lg:col-span-2">
          <article class="bg-gray-50 rounded-xl overflow-hidden border border-gray-100">
            {featuredPost.data.heroImage && (
              <img
                src={featuredPost.data.heroImage}
                alt={featuredPost.data.title}
                width="800"
                height="400"
                class="w-full h-auto"
                loading="lazy"
              />
            )}
            <div class="p-8">
              <h3 class="text-2xl font-bold text-[color:var(--color-ink)] mb-3 leading-snug">
                {featuredPost.data.title}
              </h3>
              <p class="text-gray-800 mb-4 leading-relaxed">
                {featuredPost.data.excerpt}
              </p>
              <div class="flex items-center gap-3 text-sm text-gray-700 mb-6">
                <span>Kevin</span>
                <span>&bull;</span>
                <time datetime={featuredPost.data.publishDate.toISOString()}>
                  {formatDate(featuredPost.data.publishDate)}
                </time>
              </div>
              <a
                href={`/blog/${featuredPost.id}`}
                class="inline-flex items-center px-6 py-2.5 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors"
              >
                Read More
              </a>
            </div>
          </article>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <!-- Get Tips Delivered -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="text-xl font-bold text-[color:var(--color-brand)] mb-3">Get Tips Delivered</h3>
            <p class="text-sm text-gray-800 mb-4">
              Join 2,500+ healthcare marketers getting weekly insights that actually move the needle.
            </p>
            <form class="flex gap-2">
              <div class="flex-1">
                <label for="sidebar-email" class="block text-sm font-semibold text-[color:var(--color-brand-dark)] mb-1">Email *</label>
                <input type="email" id="sidebar-email" name="email" required class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none" />
              </div>
              <button type="submit" class="self-end px-4 py-2 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors">
                Submit
              </button>
            </form>
          </div>

          <!-- Services We Offer -->
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="text-xl font-bold text-[color:var(--color-brand)] mb-4">Services We Offer</h3>
            <ul class="space-y-3">
              {SERVICES.map((s) => (
                <li>
                  <a href={s.href} class="text-[color:var(--color-brand-dark)] hover:underline font-medium">
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CATEGORY FILTERS ========== -->
  <section class="bg-white border-y border-gray-100 py-4">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-wrap gap-3 overflow-x-auto" role="tablist" aria-label="Blog category filters">
        <a
          href="/blog"
          class="px-4 py-2 text-sm font-semibold whitespace-nowrap bg-gray-100 text-gray-700 hover:bg-gray-200 rounded transition-colors"
        >
          All Posts
        </a>
        {Object.entries(CATEGORY_LABELS).map(([slug, label]) => (
          <a
            href={`/blog/category/${slug}`}
            class="px-4 py-2 text-sm font-semibold whitespace-nowrap bg-gray-100 text-gray-700 hover:bg-gray-200 rounded transition-colors"
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== POSTS GRID ========== -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {remainingPosts.map((post) => (
          <article class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
            {post.data.heroImage && (
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                width="400"
                height="200"
                loading="lazy"
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-6 flex-1 flex flex-col">
              <h3 class="text-lg font-bold text-[color:var(--color-ink)] mb-2 leading-snug">
                <a href={`/blog/${post.id}`} class="hover:text-[color:var(--color-brand-dark)]">
                  {post.data.title}
                </a>
              </h3>
              <p class="text-sm text-gray-800 mb-4 flex-1 leading-relaxed line-clamp-3">
                {post.data.excerpt}
              </p>
              <div class="flex items-center gap-2 text-xs text-gray-700 mb-4">
                <span>Kevin</span>
                <span>&bull;</span>
                <time datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
              </div>
              <a
                href={`/blog/${post.id}`}
                class="inline-flex items-center px-5 py-2 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors self-start"
              >
                Read more
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
