---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialProof from "../components/SocialProof.astro";
import { getCollection } from "astro:content";
import { PROOF_STATS, SITE } from "../lib/site";

// Services: sort by order field
const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);

const title = `${SITE.name} | Data-Driven PPC, Web Design & CRO`;
const description = "Skip the big agency runaround. Work directly with the founder on Google Ads, Meta Ads, and websites built to convert. Free strategy call available.";

const homepageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.domain,
    description: SITE.description,
    publisher: {
      "@type": "Organization",
      name: SITE.name,
      url: SITE.domain,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: SITE.name,
    url: SITE.domain,
    description: SITE.description,
    image: `${SITE.domain}/og-default.png`,
    telephone: SITE.phone,
    email: SITE.email,
    priceRange: "$$$",
    areaServed: {
      "@type": "Country",
      name: "United States",
    },
    serviceType: [
      "Google Ads Management",
      "Meta Ads Management",
      "Website Design",
      "Conversion Rate Optimization",
    ],
    audience: {
      "@type": "Audience",
      audienceType: "Healthcare Practices",
    },
  },
];
---

<BaseLayout {title} {description} extraSchema={homepageSchema}>
  <!-- ========== HERO ========== -->
  <section class="bg-gray-50 pt-16 pb-20 md:pt-24 md:pb-28 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-8 items-center">
        <div class="text-center lg:text-left">
          <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-5">
            Small Business Digital Marketing
          </p>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-[1.1] text-[color:var(--color-ink)] mb-6 tracking-tight">
            Turn Your Marketing<br />
            Into <span class="text-[color:var(--color-brand)]">Predictable Revenue</span>
          </h1>
          <p class="text-base md:text-lg text-gray-800 mb-8 leading-relaxed">
            Work directly with a founder who's scaled a healthcare business to Inc 5000 status. Get strategic guidance that goes beyond marketing - backed by proven results.
          </p>
          <a
            href="/contact"
            class="inline-flex items-center px-8 py-4 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-all shadow-xl hover:shadow-2xl text-base"
          >
            Book Your Free Consultation Today
          </a>
          <div class="mt-8 flex items-center justify-center lg:justify-start gap-4">
            <SocialProof />
          </div>
        </div>
        <div class="order-first lg:order-last">
          <img
            src="/images/hero/homepage-hero.webp"
            alt="Marketing funnel diagram showing search, social media, and leads flowing into a revenue engine with consistent bookings"
            width="640"
            height="420"
            class="w-full h-auto"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST STRIP ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-14">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-center text-white font-bold text-2xl md:text-3xl mb-10">
        Trusted by Small Businesses
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {PROOF_STATS.map((stat, i) => (
          <div class="bg-white rounded-xl p-6 text-center">
            <div class="text-[color:var(--color-brand)] text-2xl mb-2">
              {i === 0 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2 12l5 5L20 5" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 17l5-5" /></svg>
              )}
              {i === 1 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              )}
              {i === 2 && (
                <svg class="w-7 h-7 mx-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" /></svg>
              )}
            </div>
            <div class="text-3xl md:text-4xl font-bold text-[color:var(--color-brand)]" data-countup={stat.value}>{stat.value}</div>
            <div class="mt-1 text-sm text-gray-800">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PAIN ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-8 leading-tight">
        You've Built Something Great Through Word-of-Mouth. Now It's Time to Scale.
      </h2>
      <div class="space-y-6">
        <p class="text-gray-900"><strong class="text-[color:var(--color-ink)] font-extrabold">You've done the hard part</strong> - building a business that delivers real value.</p>
        <p class="text-gray-900">Your clients love you, referrals keep coming in, and <strong class="text-[color:var(--color-ink)] font-extrabold">you're proud of what you've created.</strong></p>
        <p class="text-gray-900"><strong class="text-[color:var(--color-ink)] font-extrabold">But you've hit a ceiling.</strong></p>
        <p class="text-gray-900">Your immediate network can only refer so many people, and relying solely on word-of-mouth creates that feast-or-famine cycle you're tired of.</p>
        <p class="text-gray-900">You know digital marketing could be the answer, but <strong class="text-[color:var(--color-ink)] font-extrabold">where do you even start?</strong></p>
        <p class="text-gray-900"><strong class="text-[color:var(--color-ink)] font-extrabold">Google Ads? Facebook? SEO?</strong></p>
        <p class="text-gray-900">The options are overwhelming, and you don't have time to become a marketing expert, <strong class="text-[color:var(--color-ink)] font-extrabold">you need to run your business.</strong></p>
        <p class="text-gray-900">You need a partner who understands not just marketing, but <em class="text-[color:var(--color-ink)] font-extrabold">business</em>.</p>
        <p class="text-gray-900">Someone who's been in the trenches, scaled a company, and knows what it takes to go from <strong class="text-[color:var(--color-ink)] font-extrabold">referrals to predictable revenue.</strong></p>
        <h3 class="text-2xl md:text-3xl font-bold text-[color:var(--color-brand-darker)] pt-10">That's exactly where we come in.</h3>
      </div>
    </div>
  </section>

  <!-- ========== CASE STUDY 1: PODIATRY ========== -->
  <div class="cs-scroll-container" data-cs-scroll>
    <section class="cs-sticky bg-[color:var(--color-brand-dark)] min-h-screen flex items-center overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 w-full">
        <h3 class="cs-heading text-3xl md:text-5xl font-bold text-white leading-tight mb-12 text-center">
          The Results Speak <br /><span class="cs-underline-animate">Louder Than We Do</span>
        </h3>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="cs-text">
            <h4 class="text-2xl font-bold text-white mb-4">Local Practice Achieves 63% Booking Growth</h4>
            <p class="text-lg text-gray-100 leading-relaxed">This podiatry clinic wanted to move beyond referrals. With a strategic paid search campaign, they grew bookings 63%, with Google Ads now driving 169 new patients.</p>
          </div>
          <div class="cs-image">
            <img
              src="/images/case-studies/New-Patients.webp"
              alt="Dashboard showing 63% booking growth for a podiatry practice"
              width="768"
              height="419"
              loading="lazy"
              class="w-full h-auto rounded-xl shadow-2xl border border-white/10"
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ========== WHY US ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-4 leading-tight text-center">
        We Don't Just Do Marketing, We Understand Your Business.
      </h2>
      <p class="text-center text-gray-700 mb-14 max-w-2xl mx-auto">
        We're not your typical agency. We're business consultants who happen to be marketing experts.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-14 h-14 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-3">Operations Experience</h3>
          <p class="text-gray-700 text-sm leading-relaxed">Our founder ran operations for a healthcare clinic that scaled to 5 offices and achieved Inc 5000 recognition. We understand the full picture: not just clicks and impressions, but revenue, operations, and sustainable growth.</p>
        </div>
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-14 h-14 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-3">True Partnership</h3>
          <p class="text-gray-700 text-sm leading-relaxed">You work directly with the founder. No account managers, no middlemen. We become an extension of your team, offering strategic guidance that goes beyond marketing to help your entire business thrive.</p>
        </div>
        <div class="bg-white rounded-xl p-8 text-center shadow-sm">
          <div class="w-14 h-14 rounded-lg border-2 border-[color:var(--color-brand)] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[color:var(--color-brand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-3">Data-Driven Decisions</h3>
          <p class="text-gray-700 text-sm leading-relaxed">We focus on what matters: ROI, cost per acquisition, and actual revenue generated. No vanity metrics like "impressions" or "engagement." Every dollar you invest should drive measurable business results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CASE STUDY 2: DERMATOLOGY ========== -->
  <div class="cs-scroll-container" data-cs-scroll>
    <section class="cs-sticky bg-[color:var(--color-brand-dark)] min-h-screen flex items-center overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 w-full">
        <h3 class="cs-heading text-3xl md:text-5xl font-bold text-white leading-tight mb-12 text-center">
          From Growing Practice <br /><span class="cs-underline-animate">To Market Leader</span>
        </h3>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="cs-text">
            <h4 class="text-2xl font-bold text-white mb-4">Built a Scalable Patient Acquisition Engine</h4>
            <p class="text-lg text-gray-100 leading-relaxed mb-8">A growing dermatology practice in Hawaii needed patient acquisition that could scale with them. We built a paid search engine that's driven consistent growth for nearly two years.</p>
            <a
              href="/blog/dermatology-lead-cost-case-study"
              class="inline-flex items-center px-7 py-3 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl"
            >
              Read The Case Study
            </a>
          </div>
          <div class="cs-image cs-image--rtl">
            <img
              src="/images/case-studies/Cost-Per-Lead-Dermatology.webp"
              alt="Dermatology case study results showing 1.17 million impressions, 1,617 leads, and $37 cost per lead over 22 months"
              width="1024"
              height="367"
              loading="lazy"
              class="w-full h-auto rounded-xl shadow-2xl border border-white/10"
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ========== SERVICES GRID ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] leading-tight mb-4">
          What We Do
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <article class="bg-white rounded-xl border border-gray-100 shadow-md hover:shadow-xl transition-shadow overflow-hidden flex flex-col">
            <div class="aspect-[16/10] bg-gray-50 flex items-center justify-center overflow-hidden">
              <img
                src={
                  service.id === "google-ads"
                    ? "/images/services/google-ads-hero.webp"
                    : service.id === "website-design"
                      ? "/images/services/website-design-hero.webp"
                      : `/images/services/${service.id}-illustration.png`
                }
                alt={`${service.data.title} illustration`}
                width="400"
                height="250"
                loading="lazy"
                class="w-full h-full object-contain p-4"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-xl font-bold text-[color:var(--color-ink)] mb-2">{service.data.shortTitle}</h3>
              <p class="text-gray-800 mb-6 flex-1 leading-relaxed text-sm">{service.data.description}</p>
              <a
                href={`/services/${service.id}`}
                class="inline-flex justify-center items-center px-5 py-2.5 bg-[color:var(--color-brand-dark)] text-white font-semibold text-sm rounded-md hover:bg-[color:var(--color-brand-darker)] transition-all shadow-lg hover:shadow-xl"
              >
                Read More About {service.data.shortTitle}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== SERVICES CTA BAND ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="bg-gray-100 rounded-2xl p-10 md:p-12 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[color:var(--color-ink)] leading-tight mb-4">
            Want to know which services fit your goals?
          </h2>
          <p class="text-[color:var(--color-brand-dark)] font-semibold mb-2">Book Your Free Consultation Today</p>
          <p class="text-gray-700 text-sm mb-6">Speak 1 on 1 with our Founder and Learn How You can Scale Your Business.</p>
          <a
            href="/contact"
            class="inline-flex items-center px-8 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-all shadow-xl hover:shadow-2xl text-base"
          >
            Book Today!
          </a>
        </div>
        <div class="hidden lg:block">
          <img
            src="/images/hero/google-dashboard.png"
            alt="Google Ads analytics dashboard showing campaign performance"
            width="768"
            height="768"
            loading="lazy"
            class="w-full h-auto rounded-xl shadow-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FOUNDER ========== -->
  <section class="bg-[#D8D8D8] py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <img
            src="/images/hero/kevin-reggie-selfie.jpg"
            alt="Kevin Dillon with his dog Reggie"
            width="768"
            height="1024"
            loading="lazy"
            class="w-full max-w-md h-auto rounded-xl shadow-lg mx-auto"
          />
        </div>
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[color:var(--color-ink)] mb-6 leading-tight">
            You'll Work Directly With The Founder
          </h2>
          <div class="space-y-4 text-gray-700 leading-relaxed">
            <p>Hi, I'm Kevin Dillon, the founder of Regtek Consulting. Before starting this agency, I ran operations for a healthcare clinic that scaled to five offices and achieved Inc 5000 recognition.</p>
            <p>That experience taught me what most agencies miss: marketing isn't just about clicks. It's about understanding your entire business. That's why you work directly with me. No account managers, no handoffs. Just strategic guidance from someone who's built and scaled a real business.</p>
            <p>Oh, and the name? Regtek is named after my dog, Reggie. He's the real boss around here. 🐕</p>
          </div>
          <div class="mt-8">
            <a
              href="/about"
              class="inline-flex items-center px-6 py-3 border-2 border-[color:var(--color-ink)] text-[color:var(--color-ink)] font-semibold rounded-md hover:bg-[color:var(--color-ink)] hover:text-white transition-all shadow-md hover:shadow-lg uppercase tracking-wider text-sm"
            >
              Learn More
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
        Let's Talk Growth
      </p>
      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
        Ready to Stop Guessing and Start Growing?
      </h2>
      <p class="text-lg text-gray-100 mb-10 max-w-2xl mx-auto">Book a free consultation. We'll dig into your business, your goals, and whether we're the right fit. No pressure, no pitch-deck theater.</p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl text-base"
      >
        Book A Free Consultation
      </a>
    </div>
  </section>
</BaseLayout>
