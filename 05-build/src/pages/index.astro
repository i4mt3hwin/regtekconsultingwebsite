---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import ValueProp from "../components/ValueProp.astro";
import Results from "../components/Results.astro";
import CTA from "../components/CTA.astro";
import { SITE } from "../lib/site";

const title = `${SITE.name} | Turn Your Marketing Into Predictable Revenue`;
const description =
  "Founder-led digital marketing for small businesses. Work directly with an operator who scaled a healthcare company to Inc. 5000 — strategic guidance backed by real operations experience, not agency playbooks.";
---

<BaseLayout {title} {description} hideHeader>
  <Nav />
  <Hero />
  <Stats />
  <ValueProp />
  <Results />
  <CTA />
</BaseLayout>
