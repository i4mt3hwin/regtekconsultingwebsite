---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getHomepageContent, getSiteSettings } from "../lib/content";

const home = getHomepageContent();
const site = getSiteSettings();

// Services: sort by order field
const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Featured testimonial (first one marked featured)
const testimonials = await getCollection("testimonials");
const featuredTestimonial =
  testimonials.find((t) => t.data.featured) ?? testimonials[0];

const title = `${site.siteName} | Data-Driven Marketing for Healthcare Practices`;
const description = site.description;
---

<BaseLayout {title} {description}>
  <!-- ========== HERO ========== -->
  <section class="bg-gray-50 pt-16 pb-20 md:pt-24 md:pb-28">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-5">
            {home.heroEyebrow}
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] text-[color:var(--color-ink)] mb-6 tracking-tight">
            {home.heroHeadlineLine1}<br />
            <span class="text-[color:var(--color-brand-dark)]">{home.heroHeadlineLine2}</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-600 mb-10 leading-relaxed">
            {home.heroSubtitle}
          </p>
          <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4">
            <a
              href={home.heroCtaHref}
              class="inline-flex items-center px-8 py-4 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors shadow-md text-base"
            >
              {home.heroCtaText}
              <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="/services" class="inline-flex items-center px-6 py-4 text-[color:var(--color-brand-dark)] font-semibold hover:text-[color:var(--color-brand-darker)]">
              See Services →
            </a>
          </div>
          <p class="mt-8 text-sm text-gray-500">★★★★★ &nbsp; 5-Star Client Reviews</p>
        </div>
        <div class="order-first lg:order-last">
          <img
            src="/images/hero/homepage-hero.webp"
            alt="Kevin Dillon with his dog Reggie beside a revenue engine illustration showing Google, Meta, and LinkedIn ads feeding into a lead dashboard"
            width="640"
            height="420"
            class="w-full h-auto"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST STRIP ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-14">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-gray-100 font-semibold text-xl md:text-2xl mb-8">
        {home.trustStripHeadline}
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {site.proofStats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold text-white">{stat.value}</div>
            <div class="mt-1 text-sm text-gray-200">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PAIN ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-8 leading-tight">
        {home.painHeadline}
      </h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-5">
        <p>You've done the hard part — building a business that delivers real value. Your patients love you, referrals keep coming in, and you're proud of what you've created.</p>
        <p>But you've hit a ceiling. Your immediate network can only refer so many people, and relying solely on word-of-mouth creates that feast-or-famine cycle you're tired of.</p>
        <p>You know digital marketing could be the answer. But where do you even start? Google Ads? Facebook? A new website? Most agencies will happily take your money without ever asking whether your practice can actually handle the growth.</p>
        <p class="font-semibold text-[color:var(--color-ink)]">That's where we're different.</p>
      </div>
    </div>
  </section>

  <!-- ========== RESULTS CASE STUDY ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
            {home.caseStudyEyebrow}
          </p>
          <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
            {home.caseStudyHeadlineLine1}<br />{home.caseStudyHeadlineLine2}
          </h2>
          <p class="text-lg text-gray-100 mb-10">{home.caseStudySubtitle}</p>
          <a
            href={home.caseStudyLink}
            class="inline-flex items-center px-7 py-3 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-colors shadow-md"
          >
            Read the Case Study →
          </a>
        </div>
        <div>
          <img
            src="/images/case-studies/dermatology-cost-per-lead.webp"
            alt="Dashboard showing $37 cost-per-lead result for a dermatology Google Ads campaign"
            width="640"
            height="420"
            loading="lazy"
            class="w-full h-auto rounded-xl shadow-2xl border border-white/10"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WHY US ========== -->
  <section class="bg-white py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-8 leading-tight text-center">
        {home.whyUsHeadline}
      </h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-5">
        <p>Before running digital marketing campaigns, our founder ran operations for a healthcare clinic that grew from a single location to five offices and achieved Inc&nbsp;5000 recognition.</p>
        <p>That means we understand your business model, your operations, your capacity, your customer lifetime value, and your growth constraints — not just your ad spend.</p>
        <p>Most agencies optimize for clicks and leads without asking if your practice can handle more patients. They run ads without understanding your margins. They chase vanity metrics instead of revenue.</p>
        <p class="font-semibold text-[color:var(--color-ink)]">Regtek brings operational expertise to digital marketing. We're a true strategic partner, not just an ad buyer.</p>
      </div>
      <div class="text-center mt-10">
        <a href="/about" class="inline-flex items-center text-[color:var(--color-brand-dark)] font-semibold hover:text-[color:var(--color-brand-darker)]">
          Learn More About Our Founder →
        </a>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES GRID ========== -->
  <section class="bg-gray-100 py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold text-[color:var(--color-ink)] leading-tight mb-4">
          {home.servicesHeadline}
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">{home.servicesSubtitle}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((service) => (
          <article class="bg-white rounded-xl border border-gray-100 shadow-md hover:shadow-xl transition-shadow overflow-hidden flex flex-col">
            <div class="aspect-[16/10] bg-gray-50 flex items-center justify-center overflow-hidden">
              <img
                src={`/images/services/${service.id}-illustration.png`}
                alt={`${service.data.title} illustration`}
                width="400"
                height="250"
                loading="lazy"
                class="w-full h-full object-contain p-4"
              />
            </div>
            <div class="p-8 flex flex-col flex-1">
              <h3 class="text-2xl font-bold text-[color:var(--color-ink)] mb-2">{service.data.shortTitle}</h3>
              <p class="text-sm font-semibold text-[color:var(--color-brand-dark)] mb-4">{service.data.tagline}</p>
              <p class="text-gray-600 mb-6 flex-1 leading-relaxed">{service.data.description}</p>
              <a
                href={`/services/${service.id}`}
                class="inline-flex items-center font-semibold text-[color:var(--color-brand-dark)] hover:text-[color:var(--color-brand-darker)]"
              >
                Read More About {service.data.shortTitle} →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIAL ========== -->
  {featuredTestimonial && (
    <section class="bg-white py-20 md:py-24">
      <div class="max-w-4xl mx-auto px-6">
        <figure class="text-center">
          <div class="text-[color:var(--color-brand)] text-6xl font-serif leading-none mb-4">&ldquo;</div>
          <blockquote class="text-2xl md:text-3xl font-medium text-[color:var(--color-ink)] leading-snug">
            {featuredTestimonial.data.quote}
          </blockquote>
          <figcaption class="mt-8">
            <div class="font-bold text-[color:var(--color-ink)]">{featuredTestimonial.data.author}</div>
            <div class="text-sm text-gray-500">{featuredTestimonial.data.role}</div>
          </figcaption>
        </figure>
      </div>
    </section>
  )}

  <!-- ========== FINAL CTA ========== -->
  <section class="bg-[color:var(--color-brand-dark)] py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">
        {home.finalCtaEyebrow}
      </p>
      <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
        {home.finalCtaHeadline}
      </h2>
      <p class="text-lg text-gray-100 mb-10 max-w-2xl mx-auto">{home.finalCtaSubtitle}</p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-white text-[color:var(--color-brand-dark)] font-semibold rounded-md hover:bg-gray-100 transition-colors shadow-lg text-base"
      >
        Book a Free Consultation
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
