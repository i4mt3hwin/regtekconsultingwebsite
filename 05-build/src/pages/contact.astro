---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { TESTIMONIAL, SITE } from "../lib/site";

const title = "Contact Regtek Consulting | Book a Free Strategy Call";
const description =
  "Ready to scale beyond word-of-mouth? Book a free consultation with Kevin Dillon. Direct founder access, no account managers.";
---

<BaseLayout {title} {description}>
  <section class="bg-gray-50 pt-20 pb-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-brand)] mb-4">Get in Touch</p>
      <h1 class="text-4xl md:text-5xl font-bold text-[color:var(--color-ink)] mb-5 tracking-tight">
        Learn How We Can Help You Grow
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        On our first intro call, we'll dive deep into your project and business goals, share a bit about Regtek, and see if it might be a good fit.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl font-bold text-[color:var(--color-ink)] mb-6">Why Book a Call</h2>
        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-3">
            <span class="text-[color:var(--color-brand)] font-bold text-xl leading-none mt-0.5">✓</span>
            <span class="text-gray-700">Proven track record scaling healthcare practices</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[color:var(--color-brand)] font-bold text-xl leading-none mt-0.5">✓</span>
            <span class="text-gray-700">Founder-led approach — no account managers</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[color:var(--color-brand)] font-bold text-xl leading-none mt-0.5">✓</span>
            <span class="text-gray-700">True partnership focused on your business growth</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-[color:var(--color-brand)] font-bold text-xl leading-none mt-0.5">✓</span>
            <span class="text-gray-700">Healthcare-vertical expertise — dermatology, med spa, regenerative medicine</span>
          </li>
        </ul>

        <blockquote class="bg-gray-50 rounded-xl border-l-4 border-[color:var(--color-brand)] p-6">
          <p class="italic text-gray-700 leading-relaxed">"{TESTIMONIAL.quote}"</p>
          <footer class="mt-4 text-sm">
            <div class="font-bold text-[color:var(--color-ink)]">{TESTIMONIAL.author}</div>
            <div class="text-gray-500">{TESTIMONIAL.role}</div>
          </footer>
        </blockquote>

        <p class="mt-8 text-sm text-gray-500">
          Prefer email? <a href={`mailto:${SITE.email}`} class="text-[color:var(--color-brand-dark)] font-semibold hover:underline">{SITE.email}</a>
        </p>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 shadow-md p-8">
        <h2 class="text-2xl font-bold text-[color:var(--color-ink)] mb-2">Book a Free Consultation</h2>
        <p class="text-sm text-gray-500 mb-6">
          We'll be in touch within one business day.
        </p>

        <form class="space-y-4" data-contact-form>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-1">First Name *</label>
              <input type="text" id="firstName" name="firstName" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:ring-offset-0 focus:outline-none" />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-1">Last Name</label>
              <input type="text" id="lastName" name="lastName" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none" />
            </div>
          </div>

          <div>
            <label for="company" class="block text-sm font-semibold text-gray-700 mb-1">Company / Practice Name</label>
            <input type="text" id="company" name="company" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none" />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">Email *</label>
            <input type="email" id="email" name="email" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none" />
          </div>

          <div>
            <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1">Phone</label>
            <input type="tel" id="phone" name="phone" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none" />
          </div>

          <div>
            <label for="budget" class="block text-sm font-semibold text-gray-700 mb-1">Budget</label>
            <select id="budget" name="budget" class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none">
              <option value="">Select…</option>
              <option value="300-1000">$300 – $1,000</option>
              <option value="1000-2000">$1,000 – $2,000</option>
              <option value="2000-5000">$2,000 – $5,000+</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">Message *</label>
            <textarea id="message" name="message" rows="4" required class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-[color:var(--color-brand)] focus:ring-2 focus:ring-[color:var(--color-brand)] focus:outline-none"></textarea>
          </div>

          <button type="submit" class="w-full inline-flex justify-center items-center px-6 py-3 bg-[color:var(--color-brand-dark)] text-white font-semibold rounded-md hover:bg-[color:var(--color-brand-darker)] transition-colors shadow-sm">
            Submit
          </button>
          <p class="text-xs text-gray-500 text-center">
            Form backend not wired yet — Kevin will hook up Resend after launch.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
